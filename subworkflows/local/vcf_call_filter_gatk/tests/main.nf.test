nextflow_workflow {

    name "Test Workflow VCF_CALL_FILTER_GATK"
    script "../main.nf"
    workflow "VCF_CALL_FILTER_GATK"
    config './nextflow.config'

    tag "subworkflows"
    tag "subworkflows_local"
    tag "subworkflows/vcf_call_filter_gatk"
    tag "gatk4"
    tag "gatk4/haplotypecaller"
    tag "gatk4/variantfiltration"
    tag "bcftools"
    tag "bcftools/merge"
    tag "tabix"
    tag "tabix/tabix"

    test("homo_sapiens - bam - bai - fasta - fai - dict - intervals - bed - dbsnp - dbsnp_tbi") {
        when {
            params {
                outdir = "$outputDir"
                gatk_vf_window_size = 35
                gatk_vf_cluster_size = 3
                gatk_vf_fs_filter = 30.0
                gatk_vf_qd_filter = 2.0
                gatk_hc_call_conf = 30
                skip_variantfiltration = false
            }
            workflow {
                """
                input[0] = channel.of([
                    [ id:'test1', condition: 'control' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test2.paired_end.sorted.bam', checkIfExists: true)
                ],
                    [[ id:'test2', condition: 'control' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true)
                ],
                    [[ id:'test3', condition: 'treat' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true)
                ],
                    [[ id:'test4', condition: 'treat' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.rna.paired_end.sorted.bam', checkIfExists: true)
                ])
                input[1] = channel.of([
                    [ id:'test1', condition: 'control' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test2.paired_end.sorted.bam.bai', checkIfExists: true)
                ],
                    [[ id:'test2', condition: 'control' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam.bai', checkIfExists: true)
                ],
                    [[ id:'test3', condition: 'treat' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam.bai', checkIfExists: true)
                ],
                    [[ id:'test4', condition: 'treat' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.rna.paired_end.sorted.bam.bai', checkIfExists: true)
                ])
                input[2] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                ])
                input[3] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.fai', checkIfExists: true)
                ])
                input[4] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.dict', checkIfExists: true)
                ])
                input[5] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.interval_list', checkIfExists: true)
                ])
                input[6] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.bed', checkIfExists: true)
                ])
                input[7] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/dbsnp_146.hg38.vcf.gz', checkIfExists: true)
                ])
                input[8] = channel.value([
                    [ id:'genome' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/vcf/dbsnp_146.hg38.vcf.gz.tbi', checkIfExists: true)
                ])
                input[9] = params.skip_variantfiltration
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["vcf","tbi"])).match() }
            )
        }
    }

    test("homo_sapiens - bam - bai - fasta - fai - dict - intervals - bed - dbsnp - dbsnp_tbi | skip_variantfiltration") {
        when {
            params {
                outdir = "$outputDir"
                gatk_vf_window_size = 35
                gatk_vf_cluster_size = 3
                gatk_vf_fs_filter = 30.0
                gatk_vf_qd_filter = 2.0
