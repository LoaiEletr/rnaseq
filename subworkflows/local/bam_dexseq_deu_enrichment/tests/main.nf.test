nextflow_workflow {

    name "Test Workflow BAM_DEXSEQ_DEU_ENRICHMENT"
    script "subworkflows/local/bam_dexseq_deu_enrichment/main.nf"
    workflow "BAM_DEXSEQ_DEU_ENRICHMENT"

    tag "subworkflows"
    tag "subworkflows/bam_dexseq_deu_enrichment"
    tag "dexseq"
    tag "dexseq/prepareannotation"
    tag "dexseq/count"
    tag "dexseq/deu"
    tag "go_enrichment"
    tag "kegg_enrichment"

    test("sarscov2 - bam - gtf - samplesheet | GO,KEGG enrichment") {

        when {
            params {
                outdir = "$outputDir"
                aggregation = true
                alignment_quality = 10
                pvalue_threshold = 0.05
                species_name = "human"
                logfc_threshold = 1
                top_n = 10
                min_exonlength = 18
                ntop_processes = 10
                enrichment_method = "GO,KEGG"
            }
            workflow {
                """
                input[0] = Channel.of(
                    [
                        [ id: 'RAP1_IAA_30M_REP1', lib_type: 'reverse', single_end: true ],
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true)
                    ],
                    [
                        [ id: 'RAP1_UNINDUCED_REP1', lib_type: 'reverse', single_end: true ],
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true)
                    ],
                    [
                        [ id: 'RAP1_UNINDUCED_REP2', lib_type: 'reverse', single_end: true ],
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true)
                    ],
                    [
                        [ id: 'WT_REP1', lib_type: 'reverse', single_end: true ],
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true)
                    ],
                    [
                        [ id: 'WT_REP2', lib_type: 'reverse', single_end: true ],
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true)
                    ]
                )
                input[1] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)
                input[2] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_yeast.csv', checkIfExists: true)
                input[3] = params.aggregation
                input[4] = params.alignment_quality
                input[5] = params.pvalue_threshold
                input[6] = params.logfc_threshold
                input[7] = params.top_n
                input[8] = params.min_exonlength
                input[9] = params.species_name
                input[10] = params.ntop_processes
                input[11] = params.enrichment_method.split(",")
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.significant_genes,
                    workflow.out.versions
                ).match() }
            )
        }
    }

