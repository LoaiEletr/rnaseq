nextflow_workflow {

    name "Test Workflow PIPELINE_INITIALISATION"
    script "../main.nf"
    workflow "PIPELINE_INITIALISATION"

    test("test PIPELINE_INITIALISATION successfully completes with valid parameters") {

        when {
            params {
                // Core Aligner Logic
                aligner                = null
                pseudo_aligner         = "salmon"

                // Analysis Methods
                analysis_method        = "DEG,WGCNA"

                // Input & output options
                input                  = "https://raw.githubusercontent.com/Loai3tr/test-downstream-data/refs/heads/main/rnaseq/samplesheets/samplesheet_lymphoblastoid_celllines.csv"
                outdir                 = "results"

                // Genome Config
                species                = "human"
                fasta                  = "https://raw.githubusercontent.com/nf-core/test-datasets/7f1614baeb0ddf66e60be78c3d9fa55440465ac8/reference/genome.fasta"
                gtf                    = "https://raw.githubusercontent.com/nf-core/test-datasets/7f1614baeb0ddf66e60be78c3d9fa55440465ac8/reference/genes_with_empty_tid.gtf.gz"
                transcriptome          = "https://raw.githubusercontent.com/nf-core/test-datasets/7f1614baeb0ddf66e60be78c3d9fa55440465ac8/reference/transcriptome.fasta"
                gtf_isoform            = "https://raw.githubusercontent.com/nf-core/test-datasets/7f1614baeb0ddf66e60be78c3d9fa55440465ac8/reference/genes_with_empty_tid.gtf.gz"
                // WGCNA Parameters
                tomtype                = "signed"
                networktype            = "signed"

                // Other Tool Params
                diffexpr_method        = "deseq2"
                rank_method            = "t_stat"
                cluster_method         = "hclust"
                lib_kit                = "takara"
                rrna_db_type           = "default"

                // Optional splits
                rseqc_modules          = "bam_stat,tin"
                msigdb_categories      = "H,C5"
                enrichment_method      = "GO,KEGG"
                event_types            = "SE,RI"
            }
            workflow {
                """
                input[0] = false                // version (boolean)
                input[1] = true                 // validate_parameters (boolean)
                input[2] = true                 // monochrome_logs (boolean)
                input[3] = args                 // args (array)
                input[4] = file("$outputDir")   // outdir (string)
                input[5] = null                 // input (string)
                input[6] = false                // help (boolean)
                input[7] = false                // help_full (boolean)
                input[8] = false                // show_hidden (boolean)
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success}
            )
        }

    }

}
