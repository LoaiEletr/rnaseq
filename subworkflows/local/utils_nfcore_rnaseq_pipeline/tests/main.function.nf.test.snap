    "Test Function toolCitationText": {
        "content": [
            "Tools used in the workflow included: FastQC (<a href=\"https://www.bioinformatics.babraham.ac.uk/projects/fastqc/\" target=\"_blank\">Andrews, 2010</a>), MultiQC (<a href=\"https://doi.org/10.1093/bioinformatics/btw354\" target=\"_blank\">Ewels <em>et al.</em>, 2016</a>), SeqKit (<a href=\"https://doi.org/10.1371/journal.pone.0163962\" target=\"_blank\">Shen <em>et al.</em>, 2016</a>), Kallisto (<a href=\"https://doi.org/10.1038/nbt.3519\" target=\"_blank\">Bray <em>et al.</em>, 2016</a>), Cutadapt (<a href=\"https://doi.org/10.14806/ej.17.1.200\" target=\"_blank\">Martin, 2011</a>), DESeq2 (<a href=\"https://doi.org/10.1186/s13059-014-0550-8\" target=\"_blank\">Love <em>et al.</em>, 2014</a>), tximport (<a href=\"https://doi.org/10.12688/f1000research.7563.2\" target=\"_blank\">Soneson <em>et al.</em>, 2015</a>), rhdf5 (<a href=\"https://bioconductor.org/packages/rhdf5\" target=\"_blank\">Fischer <em>et al.</em>, 2025</a>), jsonlite (<a href=\"https://doi.org/10.48550/ARXIV.1403.2805\" target=\"_blank\">Ooms, 2014</a>), biomaRt (<a href=\"https://doi.org/10.1038/nprot.2009.97\" target=\"_blank\">Durinck <em>et al.</em>, 2009</a>), pheatmap (<a href=\"https://github.com/raivokolde/pheatmap\" target=\"_blank\">Kolde, 2025</a>), EnhancedVolcano (<a href=\"https://github.com/kevinblighe/EnhancedVolcano\" target=\"_blank\">Blighe <em>et al.</em>, 2019</a>), RColorBrewer (<a href=\"https://doi.org/10.32614/cran.package.rcolorbrewer\" target=\"_blank\">Neuwirth, 2002</a>), ggplot2 (<a href=\"https://ggplot2.tidyverse.org\" target=\"_blank\">Wickham, 2016</a>), tibble (<a href=\"https://doi.org/10.32614/cran.package.tibble\" target=\"_blank\">M\u00fcller &amp; Wickham, 2016</a>), tidyr (<a href=\"https://doi.org/10.32614/cran.package.tidyr\" target=\"_blank\">Wickham <em>et al.</em>, 2014</a>), dplyr (<a href=\"https://doi.org/10.32614/cran.package.dplyr\" target=\"_blank\">Wickham <em>et al.</em>, 2014</a>), cowplot (<a href=\"https://doi.org/10.32614/cran.package.cowplot\" target=\"_blank\">Wilke, 2025</a>), clusterProfiler (<a href=\"https://doi.org/10.1016/j.xinn.2024.100722\" target=\"_blank\">Yu, 2024</a>), purrr (<a href=\"https://doi.org/10.32614/cran.package.purrr\" target=\"_blank\">Wickham &amp; Henry, 2025</a>),"
        ],
