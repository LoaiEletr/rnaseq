nextflow_workflow {

    name "Test Workflow FASTQ_QUANT_PSEUDOALIGNMENT"
    script "../main.nf"
    workflow "FASTQ_QUANT_PSEUDOALIGNMENT"
    config './nextflow.config'

    tag "subworkflows"
    tag "subworkflows_local"
    tag "subworkflows/fastq_quant_pseudoalignment"
    tag "kallisto"
    tag "kallisto/quant"
    tag "salmon"
    tag "salmon/quant"

    setup {
        run("SALMON_INDEX") {
            script "modules/local/salmon/index/main.nf"
            process {
                """
                input[0] = [[id: 'transcriptome'], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta', checkIfExists: true)]
                """
            }
        }

        run("KALLISTO_INDEX") {
            script "modules/local/kallisto/index/main.nf"
            process {
                """
                input[0] = [[id: 'transcriptome'], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta', checkIfExists: true)]
                """
            }
        }
    }

    test("sarscov2 - fastq1 - index - gtf - fragment_length - fragment_length_sd - pseudoaligner_method | kallisto") {
        when {
            params {
                outdir = "$outputDir"
                bootstrap_count = 0
                fragment_length = 200
                fragment_length_sd = 30
                pseudoaligner_method = "kallisto"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: true, lib_type: 'U' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = KALLISTO_INDEX.out.index
                input[2] = [[:], []]
                input[3] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[4] = params.fragment_length
                input[5] = params.fragment_length_sd
                input[6] = params.pseudoaligner_method
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["quant_dir", "quant_log"])).match() }
            )
        }
    }

    test("sarscov2 - [fastq1, fastq2] - index - gtf - pseudoaligner_method | kallisto") {
        when {
            params {
                outdir = "$outputDir"
                bootstrap_count = 0
                fragment_length = 200
                fragment_length_sd = 30
                pseudoaligner_method = "kallisto"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false, lib_type: 'IU' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = KALLISTO_INDEX.out.index
                input[2] = [[:], []]
                input[3] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[4] = params.fragment_length
                input[5] = params.fragment_length_sd
                input[6] = params.pseudoaligner_method
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["quant_dir", "quant_log"])).match() }
            )
        }
    }

    test("sarscov2 - fastq1 - index - gtf - pseudoaligner_method | salmon") {
        when {
            params {
                outdir = "$outputDir"
                bootstrap_count = 0
                fragment_length = 200
                fragment_length_sd = 30
                pseudoaligner_method = "salmon"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: true, lib_type: 'U' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = [[:], []]
                input[2] = SALMON_INDEX.out.index
                input[3] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[4] = params.fragment_length
                input[5] = params.fragment_length_sd
                input[6] = params.pseudoaligner_method
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["quant_dir", "quant_log"])).match() }
            )
        }
    }

    test("sarscov2 - [fastq1, fastq2] - index - gtf - pseudoaligner_method | salmon") {
        when {
            params {
                outdir = "$outputDir"
                bootstrap_count = 0
                fragment_length = 200
                fragment_length_sd = 30
                pseudoaligner_method = "salmon"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false, lib_type: 'IU' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = [[:], []]
                input[2] = SALMON_INDEX.out.index
                input[3] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[4] = params.fragment_length
                input[5] = params.fragment_length_sd
                input[6] = params.pseudoaligner_method
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["quant_dir", "quant_log"])).match() }
            )
        }
    }

    // Stub tests
    test("sarscov2 - [fastq1, fastq2] - index - gtf - fragment_length - fragment_length_sd - pseudoaligner_method - stub | kallisto") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                bootstrap_count = 0
                fragment_length = 200
                fragment_length_sd = 30
                pseudoaligner_method = "kallisto"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false, lib_type: 'IU' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = KALLISTO_INDEX.out.index
                input[2] = [[:], []]
                input[3] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[4] = params.fragment_length
                input[5] = params.fragment_length_sd
                input[6] = params.pseudoaligner_method
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }

    test("sarscov2 - [fastq1, fastq2] - index - gtf - pseudoaligner_method - stub | salmon") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                bootstrap_count = 0
                fragment_length = 200
                fragment_length_sd = 30
                pseudoaligner_method = "salmon"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false, lib_type: 'IU' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = [[:], []]
                input[2] = SALMON_INDEX.out.index
                input[3] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[4] = params.fragment_length
                input[5] = params.fragment_length_sd
                input[6] = params.pseudoaligner_method
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
