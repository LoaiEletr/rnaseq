nextflow_workflow {

    name "Test Subworkflow GTF_EXTRACTSPLICESITES_EXTRACTEXONS_BUILD_HISAT2"
    script "../main.nf"
    workflow "GTF_EXTRACTSPLICESITES_EXTRACTEXONS_BUILD_HISAT2"

    tag "subworkflows"
    tag "subworkflows/gtf_extractsplicesites_extractexons_build_hisat2"
    tag "hisat2"
    tag "hisat2/extractexons"
    tag "hisat2/extractsplicesites"
    tag "hisat2/build"

    test("sarscov2 - gtf - fasta") {
        when {
            workflow {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)
                input[1] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                """
            }
        }
        then {
            assert workflow.success
            assertAll(
                { assert workflow.out.exonssites.get(0) ==~ ".*/*.exons.tsv" },
                { assert workflow.out.splicesites.get(0) ==~ ".*/*.splice_sites.tsv" },
                { assert workflow.out.index.get(0) ==~ ".*/index" },
                { assert snapshot(workflow.out).match() }
            )
        }
    }

    test("sarscov2 - gtf - fasta - stub") {
        options "-stub"
        when {
            workflow {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)
                input[1] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta', checkIfExists: true)
                """
            }
        }
        then {
            assert workflow.success
            assertAll(
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
