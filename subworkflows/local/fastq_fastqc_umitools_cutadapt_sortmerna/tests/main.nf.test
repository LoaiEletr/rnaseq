                input[1] = file(params.adapter)
                input[2] = UNTAR.out.untar
                input[3] = params.rrna_db_type
                input[4] = params.lib_kit
                input[5] = params.with_umi
                input[6] = params.skip_umi_extract
                input[7] = params.skip_fastqc
                input[8] = params.skip_cutadapt
                input[9] = params.skip_sortmerna
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.reads,
                    workflow.out.umi_log,
                    workflow.out.trim_json,
                    workflow.out.nonrrna_log,
                    workflow.out.versions
                ).match() }
            )
        }
    }

    // Single-end tests
    test("sarscov2 single-end [fastq]") {
        when {
            params {
                outdir = "$outputDir"
                skip_fastqc       = false
                with_umi          = false
                skip_umi_extract  = false
                skip_cutadapt     = false
                skip_sortmerna    = false
                adapter = "$projectDir/assets/adapters-SE.fa"
