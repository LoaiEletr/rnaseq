                    workflow.out.umi_log,
                    workflow.out.trim_json,
                    workflow.out.versions
                ).match() }
            )
        }
    }

    // Stub tests for each configuration
    test("sarscov2 paired-end [fastq] - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                skip_fastqc       = false
                with_umi          = false
                skip_umi_extract  = false
                skip_cutadapt     = false
                skip_sortmerna    = false
                adapter = "$projectDir/assets/adapters-PE.fa"
                rrna_db_type = "default"
                lib_kit = "quantseq"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false, sequencer: 'NovaSeq' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = file(params.adapter)
