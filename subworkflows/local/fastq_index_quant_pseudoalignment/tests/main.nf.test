    test("sarscov2 - [fastq1, fastq2] - fasta - gtf | salmon") {
        when {
            params {
                outdir = "$outputDir"
                bootstrap_count = 0
                fragment_length = 200
                fragment_length_sd = 30
                pseudoaligner_method = "salmon"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false, lib_type: 'IU' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
