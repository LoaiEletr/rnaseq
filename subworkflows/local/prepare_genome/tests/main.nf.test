nextflow_workflow {

    name "Test Subworkflow PREPARE_GENOME"
    script "../main.nf"
    workflow "PREPARE_GENOME"
    config './nextflow.config'

    tag "subworkflows"
    tag "subworkflows_local"
    tag "subworkflows/prepare_genome"
    tag "gunzip"
    tag "untar"
    tag "gxf2bed"
    tag "dexseq"
    tag "dexseq/prepareannotation"
    tag "hisat2"
    tag "hisat2/extractexons"
    tag "hisat2/extractsplicesites"
    tag "hisat2/build"
    tag "kallisto"
    tag "kallisto/index"
    tag "salmon"
    tag "salmon/index"
    tag "sortmerna"
    tag "bbmap"
    tag "bbmap/bbsplit"
    tag "gatk4"
    tag "gatk4/createsequencedictionary"
    tag "gatk4/bedtointervallist"
    tag "gatk4/intervallisttools"
    tag "snpeff"
    tag "snpeff/download"
    tag "samtools"
    tag "samtools/faidx"

    // 1. HISAT2 TEST
    test("sarscov2 - hisat2 - build index") {
        when {
            params {
                outdir = "$outputDir"
                aligner         = "hisat2"
                pseudo_aligner  = null
                analysis_method = "DEG"
                skip_sortmerna  = true
                skip_bbsplit    = true
            }
            workflow {
                """
                input[0]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[3]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4]  = null
                input[5]  = null
                input[6]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[7]  = null
                input[8]  = null
                input[9]  = null
                input[10] = null
                input[11] = null
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = null
                input[16] = null
                input[17] = null
                input[18] = null
                input[19] = null
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["hisat2_index","salmon_index"])).match() }
            )
        }
    }

    // 2. KALLISTO TEST
    test("sarscov2 - kallisto - build index") {
        when {
            params {
                outdir = "$outputDir"
                pseudo_aligner  = "kallisto"
                analysis_method = "DEG"
                skip_sortmerna  = true
                skip_bbsplit    = true
            }
            workflow {
                """
                input[0]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[3]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4]  = null
                input[5]  = null
                input[6]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[7]  = null
                input[8]  = null
                input[9]  = null
                input[10] = null
                input[11] = null
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = null
                input[16] = null
                input[17] = null
                input[18] = null
                input[19] = null
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["kallisto_index", "salmon_index"])).match() }
            )
        }
    }

    // 3. SALMON TEST
    test("sarscov2 - salmon - build index") {
        when {
            params {
                outdir = "$outputDir"
                pseudo_aligner  = "salmon"
                analysis_method = "DEG"
                skip_sortmerna  = true
                skip_bbsplit    = true
            }
            workflow {
                """
                input[0]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[3]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4]  = null
                input[5]  = null
                input[6]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[7]  = null
                input[8]  = null
                input[9]  = null
                input[10] = null
                input[11] = null
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = null
                input[16] = null
                input[17] = null
                input[18] = null
                input[19] = null
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["salmon_index"])).match() }
            )
        }
    }

    // 4. SORTMERNA TEST
    test("sarscov2 - sortmerna - build index") {
        when {
            params {
                outdir = "$outputDir"
                pseudo_aligner  = null
                skip_sortmerna  = false
                skip_bbsplit    = true
                rrna_db_type    = "fast"
                analysis_method = "DEG"
            }
            workflow {
                """
                input[0]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[3]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4]  = null
                input[5]  = null
                input[6]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[7]  = 'https://github.com/biocore/sortmerna/releases/download/v4.3.4/database.tar.gz'
                input[8]  = params.rrna_db_type
                input[9]  = null
                input[10] = null
                input[11] = null
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = null
                input[16] = null
                input[17] = null
                input[18] = null
                input[19] = null
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["sortmerna_index", "salmon_index"])).match() }
            )
        }
    }

    // 5. BBSPLIT TEST
    test("sarscov2 - bbsplit - build index") {
        when {
            params {
                outdir = "$outputDir"
                pseudo_aligner  = null
                skip_sortmerna  = true
                skip_bbsplit    = false
                analysis_method = "DEG"
            }
            workflow {
                """
                input[0]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[3]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4]  = null
                input[5]  = null
                input[6]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[7]  = null
                input[8]  = null
                input[9]  = null
                input[10] = null
                input[11] = null
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = null
                input[16] = null
                input[17] = null
                input[18] = null
                input[19] = null
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["bbsplit_index", "salmon_index"])).match() }
            )
        }
    }

    // 6. GVC TEST
    test("sarscov2 - GVC - build gatk indices") {
        when {
            params {
                outdir = "$outputDir"
                pseudo_aligner  = null
                skip_sortmerna  = true
                skip_bbsplit    = true
                analysis_method         = "GVC"
                aligner                 = "hisat2"
                skip_interval_splitting = false
                gatk_interval_scatter_count = 4
            }
            workflow {
                """
                input[0]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf'
                input[3]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12'
                input[5]  = null
                input[6]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[7]  = null
                input[8]  = null
                input[9]  = null
                input[10] = null
                input[11] = null
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = null
                input[16] = null
                input[17] = null
                input[18] = null
                input[19] = 'R64-1-1.99'
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["salmon_index"])).match() }
            )
        }
    }

    // 7. FULL STUB TEST
    test("sarscov2 - all tools - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                analysis_method         = "DEG,DEU,DIU,GVC"
                aligner                 = "hisat2"
                pseudo_aligner          = "salmon"
                skip_sortmerna          = false
                skip_bbsplit            = false
                skip_interval_splitting = false
                aggregation             = true
                gatk_interval_scatter_count = 4
            }
            workflow {
                """
                input[0]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf'
                input[3]  = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12'
                input[5]  = null
                input[6]  = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[7]  = 'https://github.com/biocore/sortmerna/releases/download/v4.3.4/database.tar.gz'
                input[8]  = "fast"
                input[9]  = params.aggregation
                input[10] = null
                input[11] = null
                input[12] = null
                input[13] = null
                input[14] = null
                input[15] = null
                input[16] = null
                input[17] = null
                input[18] = null
                input[19] = 'R64-1-1.99'
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
