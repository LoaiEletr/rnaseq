                input[4] = params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz'
                input[5] = 'https://github.com/biocore/sortmerna/releases/download/v4.3.4/database.tar.gz'
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
