nextflow_workflow {

    name "Test Subworkflow PREPARE_GENOME"
    script "../main.nf"
    workflow "PREPARE_GENOME"

    tag "subworkflows"
    tag "subworkflows/PREPARE_GENOME"
    tag "gunzip"
    tag "untar"
    tag "gxf2bed"
    tag "dexseq"
    tag "dexseq/prepareannotation"
    tag "hisat2"
    tag "hisat2/extractexons"
    tag "hisat2/extractsplicesites"
    tag "hisat2/build"
    tag "kallisto"
    tag "kallisto/index"
    tag "salmon"
    tag "salmon/index"
    tag "sortmerna"
    tag "bbmap"
    tag "bbmap/bbsplit"

    test("sarscov2 - fasta - gtf - contaminant | hisat2 - with_DEU - with_RSeQC") {
        when {
            params {
                outdir = "$outputDir"
                analysis_method = "DEG,DEU"
                skip_sortmerna = true
                aligner = "hisat2"
                pseudo_aligner = "none"
                aggregation = true
                skip_bbsplit = false
                rrna_db_type = "fast"
                rseqc_modules = "tin,bamstat"
            }
            workflow {
                """
                input[0] = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1] = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2] = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[3] = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4] = null
                input[5] = null
                input[6] = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[7] = 'https://github.com/biocore/sortmerna/releases/download/v4.3.4/database.tar.gz'
                input[8] = params.rrna_db_type
                input[9] = params.aggregation
                input[10] = null
                input[11] = null
                input[12] = null
                input[13] = null
                input[14] = null
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.fasta_compressed,
                    workflow.out.fasta_uncompressed,
                    workflow.out.gtf_compressed,
                    workflow.out.gtf_uncompressed,
                    workflow.out.contaminant_fasta,
                    workflow.out.rrna_db_fasta,
                    workflow.out.versions
                ).match() }
            )
        }
    }

    test("sarscov2 - fasta - gtf - contaminant | hisat2 - with_DIU - with_SortMeRNA") {
        when {
            params {
                outdir = "$outputDir"
                analysis_method = "DIU,AS"
                skip_sortmerna = false
                aligner = "hisat2"
