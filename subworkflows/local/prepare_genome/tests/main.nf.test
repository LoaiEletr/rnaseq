nextflow_workflow {

    name "Test Subworkflow PREPARE_GENOME"
    script "../main.nf"
    workflow "PREPARE_GENOME"

    tag "subworkflows"
    tag "subworkflows/PREPARE_GENOME"
    tag "gunzip"
    tag "untar"
    tag "gxf2bed"
    tag "hisat2"
    tag "hisat2/extractexons"
    tag "hisat2/extractsplicesites"
    tag "hisat2/build"
    tag "kallisto"
    tag "kallisto/index"
    tag "salmon"
    tag "salmon/index"
    tag "sortmerna"
    tag "bbmap"
    tag "bbmap/bbsplit"

    test("sarscov2 - fasta - gtf - contaminant | with_sortmerna - with_DIU - hisat2 - with_rseqc") {
        when {
            params {
                outdir = "$outputDir"
                analysis_method = "DIU"
                skip_sortmerna = false
                aligner = "hisat2"
                pseudo_aligner = "none"
                skip_bbsplit = false
                rrna_db_type = "fast"
                rseqc_modules = "tin,bamstat,readdistribution"
            }
            workflow {
                """
                input[0] = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz'
                input[1] = params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta'
                input[2] = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[3] = params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.filtered.gtf.gz'
                input[4] = params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta'
                input[5] = 'https://github.com/biocore/sortmerna/releases/download/v4.3.4/database.tar.gz'
                input[6] = params.rrna_db_type
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(
                    workflow.out.fasta_compressed,
                    workflow.out.fasta_uncompressed,
                    workflow.out.gtf_compressed,
                    workflow.out.gtf_uncompressed,
                    workflow.out.gtf_isoform,
                    workflow.out.contaminant_fasta,
                    workflow.out.rrna_db_fasta,
                    workflow.out.versions
                ).match() }
            )
        }
    }

    test("sarscov2 - fasta - gtf - contaminant | with_sortmerna - with_DIU - hisat2 - no_rseqc") {
        when {
            params {
                outdir = "$outputDir"
