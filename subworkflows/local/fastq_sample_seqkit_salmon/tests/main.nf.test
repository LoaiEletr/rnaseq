nextflow_workflow {

    name "Test Workflow FASTQ_SAMPLE_SEQKIT_SALMON"
    script "../main.nf"
    workflow "FASTQ_SAMPLE_SEQKIT_SALMON"
    config './nextflow.config'

    tag "subworkflows"
    tag "subworkflows_local"
    tag "subworkflows/fastq_sample_seqkit_salmon"
    tag "seqkit"
    tag "seqkit/sample"
    tag "salmon"
    tag "salmon/quant"

    setup {
        run("SALMON_INDEX") {
            script "modules/local/salmon/index/main.nf"
            process {
                """
                input[0] = [[id: 'transcriptome'], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/transcriptome.fasta', checkIfExists: true)]
                """
            }
        }
    }

    test("sarscov2 - fastq1 - index - gtf") {
        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: true, lib_type: 'auto' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[2] = SALMON_INDEX.out.index
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["quant_dir"])).match() }
            )
        }
    }

    test("sarscov2 - [fastq1, fastq2] - index - gtf") {
        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false, lib_type: 'auto' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[2] = SALMON_INDEX.out.index
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["quant_dir"])).match() }
            )
        }
    }

    test("sarscov2 - fastq1 - index - gtf - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: true, lib_type: 'auto' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[2] = SALMON_INDEX.out.index
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }

    test("sarscov2 - [fastq1, fastq2] - index - gtf - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false, lib_type: 'auto' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[2] = SALMON_INDEX.out.index
                """
            }
        }
        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(workflow.out).match() }
            )
        }
    }
}
