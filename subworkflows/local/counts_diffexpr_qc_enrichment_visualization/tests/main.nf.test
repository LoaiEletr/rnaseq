nextflow_workflow {

    name "Test Workflow COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION"
    script "../main.nf"
    workflow "COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION"

    tag "subworkflows"
    tag "subworkflows_local"
    tag "subworkflows/counts_diffexpr_qc_enrichment_visualization"
    tag "edger_voom"
    tag "limma_de"
    tag "deseq2_de"
    tag "masigpro_timecourse"
    tag "qc_visualization"
    tag "de_visualization"
    tag "go_enrichment"
    tag "kegg_enrichment"
    tag "msigdb_gsea"

    test("leishmaniasis - counts - samplesheet | DESeq2 - GO enrichment") {

        when {
            params {
                outdir = "$outputDir"
                pvalue_threshold = 0.05
                logfc_threshold = 1
                ntop_genes = 100
                diffexpr_method = "deseq2"
                species_name = "human"
                nes_threshold = 1
                msigdb_categories = "C1,C2,H"
                padj_gsea = 0.05
                ntop_processes = 10
                rank_method = "logfc"
                rsq_threshold = 0.7
                cluster_method = "hclust"
                enrichment_method = "GO"
            }
            workflow {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = params.pvalue_threshold
                input[3] = params.logfc_threshold
                input[4] = params.ntop_genes
                input[5] = params.diffexpr_method
                input[6] = params.species_name
                input[7] = params.nes_threshold
                input[8] = params.msigdb_categories
                input[9] = params.padj_gsea
                input[10] = params.ntop_processes
                input[11] = params.rank_method
                input[12] = params.rsq_threshold
                input[13] = params.cluster_method
                input[14] = params.enrichment_method.split(",")
                """
            }
        }

        then {
            assertAll(
                { assert workflow.success },
                { assert snapshot(sanitizeOutput(workflow.out, unstableKeys:["voom_object", "voom_plot", "ebfit_rds", "diffgenes_table", "unfiltered_deg", "topgenes_rds", "topgenes_csv", "timecourse_clusterplots", "timecourse_clustermedian", "timecourse_summarystatistics", "timecourse_clusterassignments", "timecourse_clusterlist", "qc_plots", "volcano_plot", "heatmap_plots", "go_enrichment", "kegg_enrichment", "gsea_results"])).match() }
            )
        }
    }

