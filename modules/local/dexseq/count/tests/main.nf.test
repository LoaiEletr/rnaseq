nextflow_process {
    name "Test Process DEXSEQ_COUNT"
    script "../main.nf"
    process "DEXSEQ_COUNT"

    tag "modules"
    tag "modules_local"
    tag "dexseq"
    tag "dexseq/count"

    setup {
        run("DEXSEQ_PREPAREANNOTATION") {
            script "modules/local/dexseq/prepareannotation/main.nf"
            process {
                """
                input[0] = [[id: 'genome'], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[1] = true
                """
            }
        }
    }

    test("sarscov2 - bam - gff - alignment_quality") {
        when {
            params {
                outdir = "$outputDir"
                aggregation = true
                alignment_quality = 0
            }
            process {
                """
                input[0] = Channel.of(
                    [
                        [ id: 'test', lib_type: 'reverse', single_end: true ],
                        [
                            file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true)
                        ]
                    ]
                )
                input[1] = DEXSEQ_PREPAREANNOTATION.out.gff
                input[2] = params.alignment_quality
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.counts.get(0).get(1) ==~ ".*/*counts\\.txt" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 - bam - gff - alignment_quality - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                aggregation = true
                alignment_quality = 0
            }
            process {
                """
                input[0] = Channel.of(
                    [
                        [ id: 'test', lib_type: 'reverse', single_end: true ],
                        [
                            file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true)
                        ]
                    ]
                )
                input[1] = DEXSEQ_PREPAREANNOTATION.out.gff
                input[2] = params.alignment_quality
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
