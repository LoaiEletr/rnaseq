nextflow_process {
    name "Test Process SORTMERNA"
    script "../main.nf"
    process "SORTMERNA"

    tag "modules"
    tag "modules_local"
    tag "sortmerna"

    setup {
        run("UNTAR") {
            script "modules/local/untar/main.nf"
            process {
                """
                input[0] = [[id: 'database'], file("https://github.com/biocore/sortmerna/releases/download/v4.3.4/database.tar.gz")]
                """
            }
        }

        run("SORTMERNA", alias: "SORTMERNA_INDEX") {
            script "modules/local/sortmerna/main.nf"
            process {
                """
                input[0] = [[id: 'index'], []]
                input[1] = [[:], []]
                input[2] = UNTAR.out.untar
                input[3] = "fast"  // Use fast database
                input[4] = true  // Build index mode
                """
            }
        }
    }


    test("homo_sapiens - fastq1 - index - reference_dir - rrna_db_type | remove rRNA reads using pre-built index") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = SORTMERNA_INDEX.out.index
                input[2] = UNTAR.out.untar
                input[3] = "fast"
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.reads.get(0).get(1) ==~ ".*/test_non_rRNA_reads\\.fq\\.gz" },
                { assert process.out.log.get(0).get(1) ==~ ".*/*\\.log" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["reads", "index", "log"])).match() }
            )
        }
    }

    test("homo_sapiens - [fastq1, fastq2] - index - reference_dir - rrna_db_type | remove rRNA reads using pre-built index") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = SORTMERNA_INDEX.out.index
                input[2] = UNTAR.out.untar
                input[3] = "fast"
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.reads.get(0).get(1)[0] ==~ ".*/test_non_rRNA_reads_fwd\\.fq\\.gz" },
                { assert process.out.reads.get(0).get(1)[1] ==~ ".*/test_non_rRNA_reads_rev\\.fq\\.gz" },
                { assert process.out.log.get(0).get(1) ==~ ".*/*\\.log" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["reads", "index", "log"])).match() }
            )
        }
    }

    test("homo_sapiens - fastq1 - index - reference_dir - rrna_db_type - stub | remove rRNA reads using pre-built index") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = SORTMERNA_INDEX.out.index
                input[2] = UNTAR.out.untar
                input[3] = "fast"
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - [fastq1, fastq2] - index - reference_dir - rrna_db_type - stub | remove rRNA reads using pre-built index") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = SORTMERNA_INDEX.out.index
                input[2] = UNTAR.out.untar
                input[3] = "fast"
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
