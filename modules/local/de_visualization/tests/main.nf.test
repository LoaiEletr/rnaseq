nextflow_process {
    name "Test Process DE_VISUALIZATION"
    script "../main.nf"
    process "DE_VISUALIZATION"

    tag "modules"
    tag "modules_local"
    tag "de_visualization"

    setup {
        run("EDGER_VOOM") {
            script "modules/local/edger_voom/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                """
            }
        }

        run("LIMMA_DE") {
            script "modules/local/limma_de/main.nf"
            process {
                """
                input[0] = EDGER_VOOM.out.voom_transformed
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = 0.05
                input[3] = 1
                input[4] = 100
                """
            }
        }

        run("DESEQ2_DE") {
            script "modules/local/deseq2_de/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = 0.05
                input[3] = 1
                input[4] = 100
                """
            }
        }
    }

    test("arabidopsis - samplesheet - cluster_file - pval_threshold - logfc - diffexpr_matrix | masigpro") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_plant_timecourse.csv', checkIfExists: true)
                input[2] = file(params.pipelines_testdata_base_path + 'masigpro_results/plant_timecourse_masigpro_clusters.rds', checkIfExists: true)
                input[3] = 0.05
                input[4] = 1
                input[5] = file(params.pipelines_testdata_base_path + 'masigpro_results/plant_timecourse_masigpro_siggenes.rds', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["volcano_plot", "heatmaps"])).match() }
            )
        }
    }

    test("leishmaniasis - samplesheet - pval_threshold - logfc - hub genes list | WGCNA") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = []
                input[3] = 0.05
                input[4] = 1
                input[5] = file(params.pipelines_testdata_base_path + 'wgcna_results/leishmaniasis_wgcna_results.rds', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["volcano_plot", "heatmaps"])).match() }
            )
        }
    }

    test("arabidopsis - samplesheet - pval_threshold - logfc - hub genes list | WGCNA") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_plant_timecourse.csv', checkIfExists: true)
                input[2] = []
                input[3] = 0.05
                input[4] = 1
                input[5] = file(params.pipelines_testdata_base_path + 'wgcna_results/plant_timecourse_wgcna_results.rds', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["volcano_plot", "heatmaps"])).match() }
            )
        }
    }

    test("leishmaniasis - unfiltered_deg - samplesheet - pval_threshold - logfc - diffexpr_matrix | DESeq2") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = DESEQ2_DE.out.unfiltered_deg
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = []
                input[3] = 0.05
                input[4] = 1
                input[5] = DESEQ2_DE.out.diffgenes_matrix
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.volcano_plot.get(0) ==~ ".*/volcano_sig_genes\\.pdf" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["volcano_plot", "heatmaps"])).match() }
            )
        }
    }

    test("leishmaniasis - unfiltered_deg - samplesheet - pval_threshold - logfc - diffexpr_matrix | Limma") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = LIMMA_DE.out.unfiltered_deg_rds
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = []
                input[3] = 0.05
                input[4] = 1
                input[5] = LIMMA_DE.out.de_expression_rds
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.volcano_plot.get(0) ==~ ".*/volcano_sig_genes\\.pdf" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["volcano_plot", "heatmaps"])).match() }
            )
        }
    }

    test("leishmaniasis - unfiltered_deg - samplesheet - pval_threshold - logfc - diffexpr_matrix - stub | DESeq2") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = DESEQ2_DE.out.unfiltered_deg
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = []
                input[3] = 0.05
                input[4] = 1
                input[5] = DESEQ2_DE.out.diffgenes_matrix
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
