nextflow_process {
    name "Test Process DESEQ2_DE"
    script "../main.nf"
    process "DESEQ2_DE"

    tag "modules"
    tag "modules_local"
    tag "deseq2_de"

    test("yeast - samplesheet - pvalue_threshold - logfc  - ntop_genes | tximport matrix") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/yeast_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_yeast.csv', checkIfExists: true)
                input[2] = "0.05"      // pvalue_threshold
                input[3] = "1"         // logfc_threshold
                input[4] = "100"       // top_genes
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.unfiltered_log2counts.get(0) ==~ ".*/unfiltered_counts\\.rds" },
                { assert process.out.filtered_log2counts.get(0) ==~ ".*/filtered_counts\\.rds" },
                { assert process.out.normalized_log2counts.get(0) ==~ ".*/normalized_counts\\.rds" },
                { assert process.out.diffgenes_matrix.get(0) ==~ ".*/deseq2_de_genes\\.rds" },
                { assert process.out.vst_object.get(0) ==~ ".*/vst_transformed\\.rds" },
                { assert process.out.diffgenes_table.get(0) ==~ ".*/de_genes_full_table\\.rds" },
                { assert process.out.unfiltered_deg.get(0) ==~ ".*/unfiltered_deg_results\\.rds" },
                { assert process.out.topgenes_rds.get(0) ==~ ".*/top_100_genes\\.rds" },
                { assert process.out.topgenes_csv.get(0) ==~ ".*/top_100_genes\\.csv" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("yeast - samplesheet - pvalue_threshold - logfc  - ntop_genes | featurecounts matrix") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/featurecounts/yeast_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_yeast.csv', checkIfExists: true)
                input[2] = "0.05"      // pvalue_threshold
                input[3] = "1"         // logfc_threshold
                input[4] = "100"       // top_genes
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.unfiltered_log2counts.get(0) ==~ ".*/unfiltered_counts\\.rds" },
                { assert process.out.filtered_log2counts.get(0) ==~ ".*/filtered_counts\\.rds" },
                { assert process.out.normalized_log2counts.get(0) ==~ ".*/normalized_counts\\.rds" },
                { assert process.out.diffgenes_matrix.get(0) ==~ ".*/deseq2_de_genes\\.rds" },
                { assert process.out.vst_object.get(0) ==~ ".*/vst_transformed\\.rds" },
                { assert process.out.diffgenes_table.get(0) ==~ ".*/de_genes_full_table\\.rds" },
                { assert process.out.unfiltered_deg.get(0) ==~ ".*/unfiltered_deg_results\\.rds" },
                { assert process.out.topgenes_rds.get(0) ==~ ".*/top_100_genes\\.rds" },
                { assert process.out.topgenes_csv.get(0) ==~ ".*/top_100_genes\\.csv" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("yeast - samplesheet - pvalue_threshold - logfc  - ntop_genes - stub | tximport matrix") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/yeast_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_yeast.csv', checkIfExists: true)
                input[2] = "0.05"      // pvalue_threshold
                input[3] = "1"         // logfc_threshold
                input[4] = "100"       // top_genes
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
