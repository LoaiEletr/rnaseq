                input[2] = params.min_gs
                input[3] = params.min_mm
                input[4] = params.top_n
                input[5] = params.cor_threshold
                input[6] = params.pval_threshold
                input[7] = params.tomtype
                input[8] = params.networktype
                input[9] = params.deepsplit
                input[10] = params.reassignthreshold
                input[11] = params.mergecutheight
                input[12] = params.minmodulesize
                input[13] = params.sft_r2_threshold
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.wgcna_results.get(0) ==~ ".*/WGCNA" },
                { assert process.out.vsd_object.get(0) ==~ ".*/vsd_object\\.rds" },
                { assert process.out.unfiltered_log2counts.get(0) ==~ ".*/unfiltered_counts\\.rds" },
                { assert process.out.filtered_log2counts.get(0) ==~ ".*/filtered_counts\\.rds" },
                { assert process.out.normalized_log2counts.get(0) ==~ ".*/normalized_counts\\.rds" },
                { assert process.out.modules_hubgenes.get(0) ==~ ".*/all_traits_modules_hubgenes\\.rds" },
                { assert process.out.soft_threshold_plot.get(0) ==~ ".*/soft_threshold_selection\\.pdf" },
                { assert process.out.module_dendrogram.get(0) ==~ ".*/module_dendrogram\\.pdf" },
                { assert snapshot(
                    process.out.unfiltered_log2counts,
                    process.out.filtered_log2counts,
                    process.out.normalized_log2counts,
                    process.out.modules_hubgenes,
                    process.out.versions
                ).match() }
            )
        }
    }

