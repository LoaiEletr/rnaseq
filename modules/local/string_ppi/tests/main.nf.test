nextflow_process {
    name "Test Process STRING_PPI"
    script "../main.nf"
    process "STRING_PPI"

    tag "modules"
    tag "modules_local"
    tag "string_ppi"

    test("leishmaniasis - WGCNA results - species_name - score_threshold | no timepoints") {
        when {
            params {
                outdir = "$outputDir"
                score_threshold = 400
                species_name = "human"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'wgcna_results/leishmaniasis_wgcna_results.rds', checkIfExists: true)
                input[1] = params.species_name
                input[2] = params.score_threshold
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["string_results"])).match() }
            )
        }
    }

    test("arabidopsis - WGCNA results - species_name - score_threshold | with timepoints") {
        when {
            params {
                outdir = "$outputDir"
                score_threshold = 400
                species_name = "arabidopsis"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'wgcna_results/plant_timecourse_wgcna_results.rds', checkIfExists: true)
                input[1] = params.species_name
                input[2] = params.score_threshold
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys: ["string_results"])).match() }
            )
        }
    }

    test("leishmaniasis - WGCNA results - species_name - score_threshold - stub | no timepoints") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                score_threshold = 400
                species_name = "human"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'wgcna_results/leishmaniasis_wgcna_results.rds', checkIfExists: true)
                input[1] = params.species_name
                input[2] = params.score_threshold
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("arabidopsis - WGCNA results - species_name - score_threshold - stub | with timepoints") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                score_threshold = 400
                species_name = "arabidopsis"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'wgcna_results/plant_timecourse_wgcna_results.rds', checkIfExists: true)
                input[1] = params.species_name
                input[2] = params.score_threshold
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
