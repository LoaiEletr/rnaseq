nextflow_process {
    name "Test Process MSIGDB_GSEA"
    script "modules/local/msigdb_gsea/main.nf"
    process "MSIGDB_GSEA"

    tag "modules"
    tag "msigdb_gsea"

    setup {
        run("EDGER_VOOM") {
            script "modules/local/edger_voom/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                """
            }
        }

        run("LIMMA_DE") {
            script "modules/local/limma_de/main.nf"
            process {
                """
                input[0] = EDGER_VOOM.out.voom_transformed
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = 0.05
                input[3] = 1
                input[4] = 100
                """
            }
        }
    }

    test("Should perform GSEA using MSigDB with logFC ranking and return GSEA results") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = LIMMA_DE.out.unfiltered_deg_rds
                input[1] = 0.05
                input[2] = "human"
                input[3] = "C1"
                input[4] = 1
                input[5] = 0.25
                input[6] = 10
                input[7] = "logfc"
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.gsea_results.get(0) ==~ ".*/GSEA_results" },
                { assert snapshot(process.out.versions).match("versions_gsea_logfc") }
            )
        }
    }

    test("Should perform GSEA using MSigDB with t-statistic ranking and return GSEA results") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = LIMMA_DE.out.unfiltered_deg_rds
                input[1] = 0.05
                input[2] = "human"
                input[3] = "C1"
                input[4] = 1
                input[5] = 0.25
                input[6] = 10
                input[7] = "t_stat"
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.gsea_results.get(0) ==~ ".*/GSEA_results" },
                { assert snapshot(process.out.versions).match("versions_gsea_tstat") }
            )
        }
    }

    test("Should perform GSEA using MSigDB with signed significance ranking and return GSEA results") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = LIMMA_DE.out.unfiltered_deg_rds
                input[1] = 0.05
                input[2] = "human"
                input[3] = "C1"
                input[4] = 1
                input[5] = 0.25
                input[6] = 10
                input[7] = "signed_significance"
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.gsea_results.get(0) ==~ ".*/GSEA_results" },
                { assert snapshot(process.out.versions).match("versions_gsea_signed_significance") }
            )
        }
    }

    test("Should perform GSEA with entire MSigDB collection and return GSEA results") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = LIMMA_DE.out.unfiltered_deg_rds
                input[1] = 0.05
                input[2] = "human"
                input[3] = "C1,C2,C3,C4,C5,C6,C7,C8,H"
                input[4] = 1
                input[5] = 0.25
                input[6] = 10
                input[7] = "signed_significance"
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.gsea_results.get(0) ==~ ".*/GSEA_results" },
                { assert snapshot(process.out.versions).match("versions_gsea_msigdb_all") }
            )
        }
    }

    test("Should stub perform GSEA with entire MSigDB collection and return mocked GSEA results") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = LIMMA_DE.out.unfiltered_deg_rds
                input[1] = 0.05
                input[2] = "human"
                input[3] = "C1,C2,C3,C4,C5,C6,C7,C8,H"
                input[4] = 1
                input[5] = 0.25
                input[6] = 10
                input[7] = "logfc"
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.gsea_results.get(0) ==~ ".*/GSEA_results" },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
