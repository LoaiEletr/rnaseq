nextflow_process {
    name "Test Process MULTIQC"
    script "../main.nf"
    process "MULTIQC"

    tag "modules"
    tag "modules_local"
    tag "multiqc"

    test("sarscov2 - zip") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastqc/test_fastqc.zip', checkIfExists: true)]
                input[1] = [[:], []]
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["report", "data", "plots"])).match() }
            )
        }
    }

    test("sarscov2 - zip - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastqc/test_fastqc.zip', checkIfExists: true)]
                input[1] = [[:], []]
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
