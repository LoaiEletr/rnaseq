nextflow_process {
    name "Test Process GXF2BED"
    script "modules/local/gxf2bed/main.nf"
    process "GXF2BED"

    tag "modules"
    tag "gxf2bed"

    test("Should convert GTF to BED and return BED file") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr1/genome.gtf', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.bed.get(0) ==~ ".*/*.bed" },
                { assert snapshot(process.out.versions).match("versions") }
            )
        }
    }

    test("Should stub convert GTF to BED and return mocked BED file") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/chr1/genome.gtf', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
