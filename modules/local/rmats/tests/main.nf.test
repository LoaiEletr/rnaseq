nextflow_process {
    name "Test Process RMATS"
    script "modules/local/rmats/main.nf"
    process "RMATS"

    tag "modules"
    tag "rmats"

    setup {

        run("MAKE_BAMLIST") {
            script "modules/local/make_bamlist/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [ condition: 'treatment', lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true)
                    ]
                ],
                [
                    [ condition: 'control', lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                    ]
                ])
                """
            }
        }

        run("RMATS", alias: "RMATS_PREP") {
            script "modules/local/rmats/main.nf"
            process {
                """
                input[0] = [
                [ single_end: false, lib_type: 'forward' ],
                [
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                ]
                ]
                input[1] = MAKE_BAMLIST.out.txt.map { meta,bams -> bams}.collect()
                input[2] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)
                input[3] = "prep"
                input[4] = 50
                input[5] = false
                input[6] = false
                input[7] = false
                input[8] = false
                input[9] = []
                """
            }
        }
    }

    test("Should run rMATS for alternative splicing analysis and return results") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [
                [ single_end: false, lib_type: 'forward' ],
                [
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                ]
                ]
                input[1] = MAKE_BAMLIST.out.txt.map { meta,bams -> bams}.collect()
                input[2] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)
                input[3] = "post"
                input[4] = 50
                input[5] = false
                input[6] = false
                input[7] = false
                input[8] = false
                input[9] = RMATS_PREP.out.prep_tmp
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match("versions") }
            )
        }
    }

    test("Should stub run rMATS for alternative splicing analysis and return mocked results") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = [
                [ single_end: false, lib_type: 'forward' ],
                [
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                ]
                ]
                input[1] = MAKE_BAMLIST.out.txt.map { meta,bams -> bams}.collect()
                input[2] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)
                input[3] = "post"
                input[4] = 50
                input[5] = false
                input[6] = false
                input[7] = false
                input[8] = false
                input[9] = RMATS_PREP.out.prep_tmp
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
