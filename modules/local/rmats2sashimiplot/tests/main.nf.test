nextflow_process {
    name "Test Process RMATS2SASHIMIPLOT"
    script "modules/local/rmats2sashimiplot/main.nf"
    process "RMATS2SASHIMIPLOT"

    tag "modules"
    tag "rmats2sashimiplot"

    setup {

        run("MAKE_BAMLIST") {
            script "modules/local/make_bamlist/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [ condition: 'treatment', lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true)
                    ]
                ],
                [
                    [ condition: 'control', lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                    ]
                ])
                """
            }
        }

        run("RMATS", alias: "RMATS_PREP") {
            script "modules/local/rmats/main.nf"
            process {
                """
                input[0] = [
                [ single_end: false, lib_type: 'forward' ],
                [
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                ]
                ]
                input[1] = MAKE_BAMLIST.out.txt.map { meta,bams -> bams}.collect()
                input[2] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)
                input[3] = "prep"
                input[4] = 50
                input[5] = false
                input[6] = false
                input[7] = false
                input[8] = false
                input[9] = []
                """
            }
        }

        run("RMATS", alias: "RMATS_POST") {
            script "modules/local/rmats/main.nf"
            process {
                """
                input[0] = [
                [ single_end: false, lib_type: 'forward' ],
                [
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                ]
                ]
                input[1] = MAKE_BAMLIST.out.txt.map { meta,bams -> bams}.collect()
                input[2] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)
                input[3] = "post"
                input[4] = 50
                input[5] = false
                input[6] = false
                input[7] = false
                input[8] = false
                input[9] = RMATS_PREP.out.prep_tmp
                """
            }
        }

        run("FILTER_SIGEVENTS") {
            script "modules/local/filter_sigevents/main.nf"
            process {
                """
                input[0] = RMATS_POST.out.post_output
                input[1] = ["SE", "RI"]
                input[2] = 0.05
                input[3] = 0
                """
            }
        }
    }

    test("Should generate Sashimi plot for alternative splicing events and return plot outputs") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = FILTER_SIGEVENTS.out.sig_rmats.combine(
                    MAKE_BAMLIST.out.txt.map { meta,bams -> bams}.collect()
                )
                input[1] = [
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.sashimi_output.get(0) ==~ /.*\/sashimi_.*_out/ },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub generate Sashimi plot for alternative splicing events and return mocked plot outputs") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = FILTER_SIGEVENTS.out.sig_rmats.combine(
                    MAKE_BAMLIST.out.txt.map { meta,bams -> bams}.collect()
                )
                input[1] = [
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
