nextflow_process {
    name "Test Process PICARD_MARKDUPLICATES"
    script "modules/local/picard/markduplicates/main.nf"
    process "PICARD_MARKDUPLICATES"

    tag "modules"
    tag "modules_local"
    tag "picard"
    tag "picard/markduplicates"

    test("homo_sapiens - bam") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.value([
                    [ id: 'test', lib_type: 'reverse', single_end: false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(
                    process.out.bam,
                    process.out.findAll { key, val -> key.startsWith("versions")}
                ).match() }
            )
        }
    }

    test("homo_sapiens - bam - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.value([
                    [ id: 'test', lib_type: 'reverse', single_end: false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
