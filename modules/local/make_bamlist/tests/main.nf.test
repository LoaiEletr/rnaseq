nextflow_process {
    name "Test Process MAKE_BAMLIST"
    script "../main.nf"
    process "MAKE_BAMLIST"

    tag "modules"
    tag "modules_local"
    tag "make_bamlist"

    test("sarscov2 - bam files") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ condition: 'treatment', lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true)
                    ]
                ],
                [
                    [ condition: 'control', lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.bam', checkIfExists: true)
                    ]
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.txt.get(0).get(1) ==~ ".*/control\\.txt" },
                { assert process.out.txt.get(1).get(1) ==~ ".*/treatment\\.txt" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 - bam files - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ condition: 'treatment', lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true)
                    ]
                ],
                [
                    [ condition: 'control', lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.bam', checkIfExists: true)
                    ]
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
