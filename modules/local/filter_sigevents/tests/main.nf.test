nextflow_process {
    name "Test Process FILTER_SIGEVENTS"
    script "../main.nf"
    process "FILTER_SIGEVENTS"

    tag "modules"
    tag "modules_local"
    tag "filter_sigevents"

    setup {

        run("MAKE_BAMLIST") {
            script "modules/local/make_bamlist/main.nf"
            process {
                """
                input[0] = Channel.of(
                    [
                        [ condition: 'treatment', lib_type: 'forward' ],
                        [
                            file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                            file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true)
                        ]
                    ],
                    [
                        [ condition: 'control', lib_type: 'forward' ],
                        [
                            file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                            file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                        ]
                    ]
                )
                """
            }
        }

        run("RMATS", alias: "RMATS_PREP") {
            script "modules/local/rmats/main.nf"
            process {
                """
                input[0] = [
                    [ single_end: false, lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                    ]
                ]
                input[1] = MAKE_BAMLIST.out.txt.map {meta, bam -> [[:], bam]}.groupTuple()
                input[2] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[3] = [[:], []]
                input[4] = [[:], 50]
                input[5] = "prep"
                """
            }
        }

        run("RMATS", alias: "RMATS_POST") {
            script "modules/local/rmats/main.nf"
            process {
                """
                input[0] = [
                    [ single_end: false, lib_type: 'forward' ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.sorted.bam', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.methylated.bam', checkIfExists: true)
                    ]
                ]
                input[1] = MAKE_BAMLIST.out.txt.map {meta, bam -> [[:], bam]}.groupTuple()
                input[2] = [[:], file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.gtf', checkIfExists: true)]
                input[3] = RMATS_PREP.out.prep_tmp
                iinput[4] = [[:], 50]
                input[5] = "post"
                """
            }
        }
    }

    test("sarscov2 - [SE, RI] - fdr_cutoff - delta_psi") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = RMATS_POST.out.post_output
                input[1] = ["SE", "RI"]
                input[2] = 0.05
                input[3] = 0
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.sig_rmats.get(0).get(1) =~ ".*/*\\.filtered\\.txt" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("sarscov2 - [SE, RI] - fdr_cutoff - delta_psi - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = RMATS_POST.out.post_output
                input[1] = ["SE", "RI"]
                input[2] = 0.05
                input[3] = 0
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
