nextflow_process {
    name "Test Process GATK4_CREATESEQUENCEDICTIONARY"
    script "modules/local/gatk4/createsequencedictionary/main.nf"
    process "GATK4_CREATESEQUENCEDICTIONARY"

    tag "modules"
    tag "gatk4"
    tag "gatk4/createsequencedictionary"

    test("Should create a sequence dictionary from a zipped fasta file and return a .dict file") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz', checkIfExists: true)
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub create a sequence dictionary from a zipped fasta file and return a mocked .dict file") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/genome.fasta.gz', checkIfExists: true)
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
