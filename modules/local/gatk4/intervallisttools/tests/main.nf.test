nextflow_process {
    name "Test Process GATK4_INTERVALLISTTOOLS"
    script "modules/local/gatk4/intervallisttools/main.nf"
    process "GATK4_INTERVALLISTTOOLS"
    config './nextflow.config'

    tag "modules"
    tag "modules_local"
    tag "gatk4"
    tag "gatk4/intervallisttools"

    test("homo_sapiens - intervals") {
        when {
            params {
                outdir = "$outputDir"
                gatk_interval_scatter_count = 4
            }
            process {
                """
                input[0] = [
                    [ id:'intervals' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.filtered_intervals.interval_list', checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - intervals - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                gatk_interval_scatter_count = 4
            }
            process {
                """
                input[0] = [
                    [ id:'intervals' ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.filtered_intervals.interval_list', checkIfExists: true)
                ]
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
