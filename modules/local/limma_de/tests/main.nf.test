nextflow_process {
    name "Test Process LIMMA_DE"
    script "modules/local/limma_de/main.nf"
    process "LIMMA_DE"

    tag "modules"
    tag "limma_de"

    test("Should perform limma differential expression analysis successfully and return differential expression results") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'voom_object/yeast_voom.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_yeast.csv', checkIfExists: true)
                input[2] = "0.05"      // pvalue_threshold
                input[3] = "1"         // logfc_threshold
                input[4] = "100"       // top_genes
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.ebfit_rds.get(0) ==~ ".*/ebfit\\.rds" },
                { assert process.out.de_expression_rds.get(0) ==~ ".*/de_expression_values\\.rds" },
                { assert process.out.de_genes_rds.get(0) ==~ ".*/de_genes_full_table\\.rds" },
                { assert process.out.unfiltered_deg_rds.get(0) ==~ ".*/unfiltered_deg_results\\.rds" },
                { assert process.out.topgenes_rds.get(0) ==~ ".*/top_100_genes\\.rds" },
                { assert process.out.topgenes_csv.get(0) ==~ ".*/top_100_genes\\.csv" },
                { assert snapshot(
                    process.out.de_expression_rds,
                    process.out.de_genes_rds,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should stub perform limma differential expression analysis successfully and return mocked differential expression results") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'voom_object/yeast_voom.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_yeast.csv', checkIfExists: true)
                input[2] = "0.05"      // pvalue_threshold
                input[3] = "1"         // logfc_threshold
                input[4] = "100"       // top_genes
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.ebfit_rds.get(0) ==~ ".*/ebfit\\.rds" },
                { assert process.out.de_expression_rds.get(0) ==~ ".*/de_expression_values\\.rds" },
                { assert process.out.de_genes_rds.get(0) ==~ ".*/de_genes_full_table\\.rds" },
                { assert process.out.unfiltered_deg_rds.get(0) ==~ ".*/unfiltered_deg_results\\.rds" },
                { assert process.out.topgenes_rds.get(0) ==~ ".*/top_100_genes\\.rds" },
                { assert process.out.topgenes_csv.get(0) ==~ ".*/top_100_genes\\.csv" },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
