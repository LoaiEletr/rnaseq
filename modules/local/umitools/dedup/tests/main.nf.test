nextflow_process {
    name "Test Process UMITOOLS_DEDUP"
    script "modules/local/umitools/dedup/main.nf"
    process "UMITOOLS_DEDUP"

    tag "modules"
    tag "umitools"
    tag "umitools/dedup"

    test("Should deduplicate single-end BAM with UMIs and return deduplicated BAM with logs and TSV files") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' , single_end: true ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam.bai', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.bam.get(0).get(1) ==~ ".*/test\\.umi_dedup\\.bam" },
                { assert process.out.log.get(0).get(1) ==~ ".*/test\\.umi_dedup\\.log" },
                { assert process.out.tsv_edit_distance.get(0).get(1) ==~ ".*/*edit_distance\\.tsv" },
                { assert process.out.tsv_per_umi.get(0).get(1) ==~ ".*/*per_umi\\.tsv" },
                { assert process.out.tsv_umi_per_position.get(0).get(1) ==~ ".*/*per_position\\.tsv" },
                { assert snapshot(
                    process.out.bam,
                    process.out.tsv_per_umi,
                    process.out.tsv_umi_per_position,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should deduplicate paired-end BAM with UMIs and return deduplicated BAM with logs and TSV files") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' , single_end: false ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam.bai', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.bam.get(0).get(1) ==~ ".*/test\\.umi_dedup\\.bam" },
                { assert process.out.log.get(0).get(1) ==~ ".*/test\\.umi_dedup\\.log" },
                { assert process.out.tsv_edit_distance.get(0).get(1) ==~ ".*/*edit_distance\\.tsv" },
                { assert process.out.tsv_per_umi.get(0).get(1) ==~ ".*/*per_umi\\.tsv" },
                { assert process.out.tsv_umi_per_position.get(0).get(1) ==~ ".*/*per_position\\.tsv" },
                { assert snapshot(
                    process.out.bam,
                    process.out.tsv_per_umi,
                    process.out.tsv_umi_per_position,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should stub deduplicate single-end BAM with UMIs and return mocked deduplicated BAM with logs and TSV files") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' , single_end: true ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.single_end.sorted.bam.bai', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub deduplicate paired-end BAM with UMIs and return mocked deduplicated BAM with logs and TSV files") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' , single_end: false ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true),
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam.bai', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
