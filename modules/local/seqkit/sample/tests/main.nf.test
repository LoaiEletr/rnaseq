nextflow_process {
    name "Test Process SEQKIT_SAMPLE"
    script "modules/local/seqkit/sample/main.nf"
    process "SEQKIT_SAMPLE"

    tag "modules"
    tag "seqkit"
    tag "seqkit/sample"

    test("Should subsample single-end FASTQ to 1M reads and return sampled FASTQ file") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.reads.get(0).get(1) ==~ ".*/*_1M\\.fastq\\.gz" },
                { assert process.out.log.get(0).get(1) ==~ ".*/*\\.log" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should subsample paired-end FASTQ to 1M reads and return sampled FASTQ files") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.reads.get(0).get(1)[0] ==~ ".*/*_1_1M\\.fastq\\.gz" },
                { assert process.out.reads.get(0).get(1)[1] ==~ ".*/*_2_1M\\.fastq\\.gz" },
                { assert process.out.log.get(0).get(1)[0] ==~ ".*/*\\.log" },
                { assert process.out.log.get(0).get(1)[1] ==~ ".*/*\\.log" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub subsample single-end FASTQ to 1M reads and return mocked sampled FASTQ file") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub subsample paired-end FASTQ to 1M reads and return mocked sampled FASTQ files") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
