nextflow_process {
    name "Test Process HISAT2_ALIGN"
    script "modules/local/hisat2/align/main.nf"
    process "HISAT2_ALIGN"

    tag "modules"
    tag "hisat2"
    tag "hisat2/align"

    setup {
        run("HISAT2_EXTRACTEXONS") {
            script "modules/local/hisat2/extractexons/main.nf"
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.gtf', checkIfExists: true)
                """
            }
        }

        run("HISAT2_EXTRACTSPLICESITES") {
            script "modules/local/hisat2/extractsplicesites/main.nf"
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.gtf', checkIfExists: true)
                """
            }
        }

        run("HISAT2_BUILD") {
            script "modules/local/hisat2/build/main.nf"
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                input[1] = HISAT2_EXTRACTSPLICESITES.out.splice_sites
                input[2] = HISAT2_EXTRACTEXONS.out.exons_sites
                """
            }
        }
    }

    test("Should align single-end reads against reference genome using built index and return BAM file with summary") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', lib_type: 'forward', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = HISAT2_BUILD.out.index
                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.bam.get(0).get(1) ==~ ".*/test\\.bam"},
                { assert process.out.summary.get(0).get(1) ==~ ".*/*.hisat2\\.summary"},
                { assert snapshot(
                    process.out.summary,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should align paired-end reads against reference genome using built index and return BAM file with summary") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', lib_type: 'reverse', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = HISAT2_BUILD.out.index
                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.bam.get(0).get(1) ==~ ".*/test\\.bam"},
                { assert process.out.summary.get(0).get(1) ==~ ".*/*.hisat2\\.summary"},
                { assert snapshot(
                    process.out.summary,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should stub align single-end reads against reference genome using built index and return mocked BAM file with summary") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', lib_type: 'forward', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = HISAT2_BUILD.out.index
                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub align paired-end reads against reference genome using built index and return mocked BAM file with summary") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', lib_type: 'reverse', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = HISAT2_BUILD.out.index
                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
