nextflow_process {
    name "Test Process BEDTOOLS_SORT"
    script "../main.nf"
    process "BEDTOOLS_SORT"

    tag "modules"
    tag "modules_local"
    tag "bedtools"
    tag "bedtools/sort"

    test("homo_sapiens - bed") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [id : 'test'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.bed', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.bed.get(0).get(1) ==~ ".*/*.sorted\\.bed" },
                { assert snapshot(process.out).match() },
            )
        }
    }

    test("homo_sapiens - bed - stub") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [id : 'test'],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/scramble/test.bed', checkIfExists: true)
                ])
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() },
            )
        }
    }
}
