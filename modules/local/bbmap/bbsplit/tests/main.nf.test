nextflow_process {
    name "Test Process BBMAP_BBSPLIT"
    script "../main.nf"
    process "BBMAP_BBSPLIT"
    config './nextflow.config'

    tag "modules"
    tag "modules_local"
    tag "bbmap"
    tag "bbmap/bbsplit"

    setup {
        run("BBMAP_BBSPLIT", alias: "BBMAP_BBSPLIT_INDEX") {
            script "modules/local/bbmap/bbsplit/main.nf"
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    []
                ])
                input[1] = [[:], []]
                input[2] = channel.value([[ id: 'test' ],file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)])
                input[3] = channel.value([[ id: 'test' ],file(params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.fa.gz', checkIfExists: true)])
                input[4] = true
                """
            }
        }
    }

    test("homo_sapiens - primary_ref - other_ref | build index") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    []
                ])
                input[1] = [[:],[]]
                input[2] = channel.value([[ id: 'test' ],file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)])
                input[3] = channel.value([[ id: 'test' ],file(params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.fa.gz', checkIfExists: true)])
                input[4] = true
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["index"])).match() }
            )
        }
    }

    test("homo_sapiens - fastq1 - index | split using pre-built index") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', condition: 'treated', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = BBMAP_BBSPLIT_INDEX.out.index
                input[2] = [[:],[]]
                input[3] = [[:],[]]
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.reads.get(0).get(1) ==~ ".*/test_.*\\.fastq\\.gz" },
                { assert process.out.stats.get(0).get(1) ==~ ".*/test\\.bbsplit_stats\\.txt" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["reads","index","stats"])).match() }
            )
        }
    }

    test("homo_sapiens - [fastq1, fastq2] - index | split using pre-built index") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test', condition: 'control', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])

                input[1] = BBMAP_BBSPLIT_INDEX.out.index
                input[2] = [[:],[]]
                input[3] = [[:],[]]
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.reads.get(0).get(1)[0] ==~ ".*/test_.*_1\\.fastq\\.gz" },
                { assert process.out.reads.get(0).get(1)[1] ==~ ".*/test_.*_2\\.fastq\\.gz" },
                { assert process.out.stats.get(0).get(1) ==~ ".*/test\\.bbsplit_stats\\.txt" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["reads","index","stats"])).match() }
            )
        }
    }

    test("homo_sapiens - primary_ref - other_ref - stub | build index") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test' ],
                    []
                ])
                input[1] = [[:],[]]
                input[2] = channel.value([[ id: 'test' ],file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)])
                input[3] = channel.value([[ id: 'test' ],file(params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.fa.gz', checkIfExists: true)])
                input[4] = true
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - fastq1 - index - stub | split using pre-built index") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', condition: 'treated', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = BBMAP_BBSPLIT_INDEX.out.index
                input[2] = [[:],[]]
                input[3] = [[:],[]]
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("homo_sapiens - [fastq1, fastq2] - index - stub | split using pre-built index") {

        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test', condition: 'control', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])
                input[1] = BBMAP_BBSPLIT_INDEX.out.index
                input[2] = [[:],[]]
                input[3] = [[:],[]]
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
