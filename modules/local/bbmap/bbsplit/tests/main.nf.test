nextflow_process {
    name "Test Process BBMAP_BBSPLIT"
    script "modules/local/bbmap/bbsplit/main.nf"
    process "BBMAP_BBSPLIT"

    tag "modules"
    tag "bbmap"
    tag "bbmap/bbsplit"

    setup {
        run("BBMAP_BBSPLIT", alias: "BBMAP_BBSPLIT_INDEX") {
            script "modules/local/bbmap/bbsplit/main.nf"
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test' ],
                    []
                ])


                input[1] = []


                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)


                input[3] = file(params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.fa.gz', checkIfExists: true)


                input[4] = true
                """
            }
        }
    }

    test("Should build BBSplit index using human genome as primary reference and mouse chr19 as other reference") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test' ],
                    []
                ])


                input[1] = []


                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)


                input[3] = file(params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.fa.gz', checkIfExists: true)


                input[4] = true
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out.versions).match("versions_build_index") }
            )
        }
    }

    test("Should split single-end reads between human and mouse references using pre-built index") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test', condition: 'treated', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])


                input[1] = BBMAP_BBSPLIT_INDEX.out.index


                input[2] = []


                input[3] = []


                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                {

                    def reads = process.out.reads.get(0).get(1)
                    assert reads ==~ ".*/test_.*\\.fastq\\.gz"
                },
                { assert process.out.stats.get(0) ==~ ".*/test\\.bbsplit_stats\\.txt" },
                { assert snapshot(process.out.versions).match("versions_single_end") }
            )
        }
    }

    test("Should split paired-end reads between human and mouse references using pre-built index") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test', condition: 'control', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])

                input[1] = BBMAP_BBSPLIT_INDEX.out.index
                input[2] = []
                input[3] = []
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                {

                    def reads = process.out.reads.get(0).get(1)
                    assert reads.size() == 2
                    assert reads[0] ==~ ".*/test_.*_1\\.fastq\\.gz"
                    assert reads[1] ==~ ".*/test_.*_2\\.fastq\\.gz"
                },
                { assert process.out.stats.get(0) ==~ ".*/test\\.bbsplit_stats\\.txt" },
                { assert snapshot(process.out.versions).match("versions_paired_end") }
            )
        }
    }


    test("Should stub BBSplit index building using human genome as primary reference and mouse chr19 as other reference") {

        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test' ],
                    []
                ])


                input[1] = []


                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)


                input[3] = file(params.modules_testdata_base_path + 'genomics/mus_musculus/genome/chr19.fa.gz', checkIfExists: true)


                input[4] = true
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }


    test("Should stub split single-end reads between human and mouse references using pre-built index") {

        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test', condition: 'treated', single_end: true ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true)
                    ]
                ])


                input[1] = BBMAP_BBSPLIT_INDEX.out.index


                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)


                input[3] = []


                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }


    test("Should stub split paired-end reads between human and mouse references using pre-built index") {

        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """

                input[0] = Channel.of([
                    [ id: 'test', condition: 'control', single_end: false ],
                    [
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_1.fastq.gz', checkIfExists: true),
                        file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/fastq/test_2.fastq.gz', checkIfExists: true)
                    ]
                ])

                input[1] = BBMAP_BBSPLIT_INDEX.out.index
                input[2] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.fasta.gz', checkIfExists: true)
                input[3] = []
                input[4] = false
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

}
