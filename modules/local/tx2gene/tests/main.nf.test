nextflow_process {
    name "Test Process TX2GENE"
    script "../main.nf"
    process "TX2GENE"

    tag "modules"
    tag "modules_local"
    tag "tx2gene"

    test("human - species_name") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = "human"
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert process.out.tsv.get(0) ==~ ".*/tx2gene\\.tsv" },
                { assert snapshot(process.out).match() }
            )
        }
    }

