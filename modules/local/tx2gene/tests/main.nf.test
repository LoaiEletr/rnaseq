nextflow_process {
    name "Test Process TX2GENE"
    script "modules/local/tx2gene/main.nf"
    process "TX2GENE"

    tag "modules"
    tag "tx2gene"

    test("Should generate transcript-to-gene mapping file for human species and return TSV file") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = "human"
                """
            }
        }
        then {
            assertAll (
                { assert process.success },
                { assert process.out.tsv.get(0) ==~ ".*/tx2gene\\.tsv" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should generate transcript-to-gene mapping file for mouse species and return TSV file") {
