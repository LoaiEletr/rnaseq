nextflow_process {
    name "Test Process MASIGPRO_TIMECOURSE"
    script "modules/local/masigpro_timecourse/main.nf"
    process "MASIGPRO_TIMECOURSE"

    tag "modules"
    tag "masigpro_timecourse"

    test("Should perform timecourse analysis using maSigPro package with hierarchical cluster method and return timecourse results") {
        when {
            params {
                outdir = "$outputDir"
                rsq_threshold = 0.8
                cluster_method = "hclust"
                pvalue_threshold = 0.05
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/featurecounts/plant_timecourse_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_plant_timecourse.csv', checkIfExists: true)
                input[2] = params.pvalue_threshold
                input[3] = params.rsq_threshold
                input[4] = params.cluster_method
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.masigpro_results.get(0) ==~ ".*/masigpro_results" },
                { assert process.out.unfiltered_log2cpm.get(0) ==~ ".*/unfiltered_log2cpm\\.rds" },
                { assert process.out.filtered_log2cpm.get(0) ==~ ".*/filtered_log2cpm\\.rds" },
                { assert process.out.normalized_log2cpm.get(0) ==~ ".*/normalized_log2cpm\\.rds" },
                { assert process.out.cluster_plots.get(0) ==~ ".*/*clusterplots\\.pdf" },
                { assert process.out.cluster_median_expression.get(0) ==~ ".*/*median_expression\\.csv" },
                { assert process.out.summary_statistics.get(0) ==~ ".*/*statistics\\.csv" },
                { assert process.out.cluster_assignments.get(0) ==~ ".*/*assignments\\.csv" },
                { assert process.out.clusters_list.get(0) ==~ ".*/clusters_list\\.rds" },
                { assert process.out.significant_expression.get(0) ==~ ".*/expression_matrix_siggenes\\.rds" },
                { assert snapshot(
                    process.out.unfiltered_log2cpm,
                    process.out.filtered_log2cpm,
                    process.out.normalized_log2cpm,
                    process.out.filtered_log2cpm,
                    process.out.cluster_median_expression,
                    process.out.summary_statistics,
                    process.out.cluster_assignments,
                    process.out.clusters_list,
                    process.out.significant_expression,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should perform timecourse analysis using maSigPro package with Mclust cluster method and return timecourse results") {
        when {
            params {
                outdir = "$outputDir"
                rsq_threshold = 0.8
                cluster_method = "Mclust"
                pvalue_threshold = 0.05
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/featurecounts/plant_timecourse_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_plant_timecourse.csv', checkIfExists: true)
                input[2] = params.pvalue_threshold
                input[3] = params.rsq_threshold
                input[4] = params.cluster_method
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.masigpro_results.get(0) ==~ ".*/masigpro_results" },
                { assert process.out.unfiltered_log2cpm.get(0) ==~ ".*/unfiltered_log2cpm\\.rds" },
                { assert process.out.filtered_log2cpm.get(0) ==~ ".*/filtered_log2cpm\\.rds" },
                { assert process.out.normalized_log2cpm.get(0) ==~ ".*/normalized_log2cpm\\.rds" },
                { assert process.out.cluster_plots.get(0) ==~ ".*/*clusterplots\\.pdf" },
                { assert process.out.cluster_median_expression.get(0) ==~ ".*/*median_expression\\.csv" },
                { assert process.out.summary_statistics.get(0) ==~ ".*/*statistics\\.csv" },
                { assert process.out.cluster_assignments.get(0) ==~ ".*/*assignments\\.csv" },
                { assert process.out.clusters_list.get(0) ==~ ".*/clusters_list\\.rds" },
                { assert process.out.significant_expression.get(0) ==~ ".*/expression_matrix_siggenes\\.rds" },
                { assert snapshot(
                    process.out.unfiltered_log2cpm,
                    process.out.filtered_log2cpm,
                    process.out.normalized_log2cpm,
                    process.out.filtered_log2cpm,
                    process.out.cluster_median_expression,
                    process.out.summary_statistics,
                    process.out.cluster_assignments,
                    process.out.clusters_list,
                    process.out.significant_expression,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should stub perform timecourse analysis using maSigPro package with hierarchical cluster method and return mocked timecourse results") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                rsq_threshold = 0.8
                cluster_method = "hclust"
                pvalue_threshold = 0.05
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/featurecounts/plant_timecourse_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_plant_timecourse.csv', checkIfExists: true)
                input[2] = params.pvalue_threshold
                input[3] = params.rsq_threshold
                input[4] = params.cluster_method
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub perform timecourse analysis using maSigPro package with Mclust cluster method and return mocked timecourse results") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
                input = "$projectDir/assets/masigpro/GSE39463.csv"
                rsq_threshold = 0.8
                cluster_method = "Mclust"
                pvalue_threshold = 0.05
            }
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/featurecounts/plant_timecourse_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_plant_timecourse.csv', checkIfExists: true)
                input[2] = params.pvalue_threshold
                input[3] = params.rsq_threshold
                input[4] = params.cluster_method
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
