nextflow_process {
    name "Test Process EDGER_VOOM"
    script "modules/local/edger_voom/main.nf"
    process "EDGER_VOOM"

    tag "modules"
    tag "edger_voom"

    setup {
        run("TX2GENE") {
            script "modules/local/tx2gene/main.nf"
            process {
                """
                input[0] = "yeast"
                """
            }
        }

        run("UNTAR") {
            script "modules/local/untar/main.nf"
            process {
                """
                input[0] = file(params.modules_testdata_base_path + 'genomics/eukaryotes/saccharomyces_cerevisiae/kallisto_results.tar.gz', checkIfExists: true)
                """
            }
        }

        run("TXIMPORT") {
            script "modules/local/tximport/main.nf"
            process {
                """
                input[0] = UNTAR.out.untar
                .map { dir ->
                    dir.listFiles().findAll { it.isDirectory() }
                }
                input[1] = "kallisto"
                input[2] = TX2GENE.out.tsv
                """
            }
        }
    }

    test("Should run edgeR with voom transformation successfully and return Voom results with plots") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = TXIMPORT.out.rds
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_yeast.csv', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.unfiltered_log2cpm.get(0) ==~ ".*/unfiltered_log2cpm\\.rds" },
                { assert process.out.filtered_log2cpm.get(0) ==~ ".*/filtered_log2cpm\\.rds" },
                { assert process.out.normalized_log2cpm.get(0) ==~ ".*/normalized_log2cpm\\.rds" },
                { assert process.out.voom_transformed.get(0) ==~ ".*/voom_transformed\\.rds" },
                { assert process.out.voom_plot.get(0) ==~ ".*/voom_plot\\.pdf" },
                { assert snapshot(
                    process.out.unfiltered_log2cpm,
                    process.out.filtered_log2cpm,
                    process.out.normalized_log2cpm,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should stub run edgeR with voom transformation successfully and return mocked Voom results with plots") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = TXIMPORT.out.rds
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_yeast.csv', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
