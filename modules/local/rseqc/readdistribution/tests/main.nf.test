nextflow_process {
    name "Test Process RSEQC_READDISTRIBUTION"
    script "modules/local/rseqc/readdistribution/main.nf"
    process "RSEQC_READDISTRIBUTION"

    tag "modules"
    tag "rseqc"
    tag "rseqc/readdistribution"

    test("Should calculate read distribution across genomic features with RSeQC and return distribution TXT file") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true)
                ])
                input[1] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.txt.get(0).get(1) ==~ ".*/test\\.read_distribution\\.txt" },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub calculate read distribution across genomic features with RSeQC and return mocked distribution TXT file") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    file(params.modules_testdata_base_path + 'genomics/sarscov2/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true)
                ])
                input[1] = file(params.modules_testdata_base_path + 'genomics/sarscov2/genome/bed/test.bed12', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
