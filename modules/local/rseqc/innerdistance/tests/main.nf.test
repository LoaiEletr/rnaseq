nextflow_process {
    name "Test Process RSEQC_INNERDISTANCE"
    script "modules/local/rseqc/innerdistance/main.nf"
    process "RSEQC_INNERDISTANCE"

    tag "modules"
    tag "rseqc"
    tag "rseqc/innerdistance"

    test("Should calculate inner distance for RNA-seq data with RSeQC and return distance files with PDF and R script") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true)
                ])
                input[1] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.bed', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.distance.get(0).get(1) =~ ".*/*distance\\.txt" },
                { assert process.out.freq.get(0).get(1) =~ ".*/*freq\\.txt" },
                { assert process.out.pdf.get(0).get(1) =~ ".*/*\\.pdf" },
                { assert process.out.rscript.get(0).get(1) =~ ".*/*\\.r" },
                { assert snapshot(
                    process.out.distance,
                    process.out.freq,
                    process.out.rscript,
                    process.out.versions
                ).match() }
            )
        }
    }

    test("Should stub calculate inner distance for RNA-seq data with RSeQC and return mocked distance files with PDF and R script") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                    [ id: 'test', single_end: false ],
                    file(params.modules_testdata_base_path + 'genomics/homo_sapiens/illumina/bam/test.paired_end.sorted.bam', checkIfExists: true)
                ])
                input[1] = file(params.modules_testdata_base_path + 'genomics/homo_sapiens/genome/genome.bed', checkIfExists: true)
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
