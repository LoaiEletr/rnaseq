                input[7] = []
                input[8] = 10
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.go_results.get(0) ==~ ".*/GO_results" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["go_results"])).match() }
            )
        }
    }

    test("arabidopsis - pvalue_threshold - logfc - species_name - WGCNA list - ntop_processes | WGCNA") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = 0.05
                input[2] = 1
                input[3] = "arabidopsis"
                input[4] = file(params.pipelines_testdata_base_path + 'wgcna_results/plant_timecourse_wgcna_results.rds', checkIfExists: true)
                input[5] = []
