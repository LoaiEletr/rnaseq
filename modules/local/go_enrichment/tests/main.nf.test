nextflow_process {
    name "Test Process GO_ENRICHMENT"
    script "../main.nf"
    process "GO_ENRICHMENT"

    tag "modules"
    tag "modules_local"
    tag "go_enrichment"

    setup {
        run("EDGER_VOOM") {
            script "modules/local/edger_voom/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                """
            }
        }

        run("LIMMA_DE") {
            script "modules/local/limma_de/main.nf"
            process {
                """
                input[0] = EDGER_VOOM.out.voom_transformed
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = 0.05
                input[3] = 1
                input[4] = 100
                """
            }
        }

        run("DESEQ2_DE") {
            script "modules/local/deseq2_de/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = 0.05
                input[3] = 1
                input[4] = 100
                """
            }
        }
    }

    test("leishmaniasis - unfiltered_deg - pvalue_threshold - logfc - species_name - ntop_processes | DESeq2") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = DESEQ2_DE.out.unfiltered_deg
                input[1] = 0.05
                input[2] = 1
                input[3] = "human"
                input[4] = []
                input[5] = []
                input[6] = []
                input[7] = []
                input[8] = 10
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.go_results.get(0) ==~ ".*/GO_results" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["go_results"])).match() }
            )
        }
    }

    test("leishmaniasis - unfiltered_deg - pvalue_threshold - logfc - species_name - ntop_processes | Limma") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = LIMMA_DE.out.unfiltered_deg_rds
                input[1] = 0.05
                input[2] = 1
                input[3] = "human"
                input[4] = []
                input[5] = []
                input[6] = []
                input[7] = []
                input[8] = 10
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.go_results.get(0) ==~ ".*/GO_results" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["go_results"])).match() }
            )
        }
    }

    test("lymphoblastoid - pvalue_threshold - logfc - species_name - DEU genes - ntop_processes | DEXSeq") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = 0.05
                input[2] = 1
                input[3] = "human"
                input[4] = []
                input[5] = []
                input[6] = []
                input[7] = file(params.pipelines_testdata_base_path + 'diu_deu_results/lymphoblastoid_celllines_DEU_gene_ids.rds', checkIfExists: true)
                input[8] = 10
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.go_results.get(0) ==~ ".*/GO_results" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["go_results"])).match() }
            )
        }
    }

