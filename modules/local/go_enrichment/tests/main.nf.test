                input[7] = []
                input[8] = 10
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.go_results.get(0) ==~ ".*/GO_results" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["go_results"])).match() }
            )
        }
    }

    test("leishmaniasis - unfiltered_deg - pvalue_threshold - logfc - species_name - ntop_processes - stub | DESeq2") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = DESEQ2_DE.out.unfiltered_deg
                input[1] = 0.05
                input[2] = 1
                input[3] = "human"
                input[4] = []
                input[5] = []
                input[6] = []
                input[7] = []
                input[8] = 10
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("leishmaniasis - pvalue_threshold - logfc - species_name - WGCNA list - ntop_processes - stub | WGCNA") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = 0.05
                input[2] = 1
                input[3] = "human"
                input[4] = file(params.pipelines_testdata_base_path + 'wgcna_results/leishmaniasis_wgcna_results.rds', checkIfExists: true)
                input[5] = []
                input[6] = []
                input[7] = []
                input[8] = 10
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
