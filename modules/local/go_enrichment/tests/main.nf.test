        }
    }

    test("leishmaniasis - pvalue_threshold - logfc - species_name - WGCNA list - ntop_processes | WGCNA") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = 0.05
                input[2] = 1
                input[3] = "human"
                input[4] = file(params.pipelines_testdata_base_path + 'wgcna_results/leishmaniasis_wgcna_results.rds', checkIfExists: true)
                input[5] = []
