nextflow_process {
    name "Test Process QC_VISUALIZATION"
    script "modules/local/qc_visualization/main.nf"
    process "QC_VISUALIZATION"

    tag "modules"
    tag "qc_visualization"

    setup {
        run("EDGER_VOOM") {
            script "modules/local/edger_voom/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                """
            }
        }

        run("DESEQ2_DE") {
            script "modules/local/deseq2_de/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = 0.05
                input[3] = 1
                input[4] = 100
                """
            }
        }
    }

    test("Should generate QC plots (MDS, violin, PCA) from edgeR data and return PDF plots") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = EDGER_VOOM.out.voom_transformed
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = EDGER_VOOM.out.unfiltered_log2cpm
                input[3] = EDGER_VOOM.out.filtered_log2cpm
                input[4] = EDGER_VOOM.out.normalized_log2cpm
                input[5] = []
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.qc_plots.get(0) ==~ ".*/qc_plots" },
                { assert snapshot(process.out.versions).match("versions_qcplots_edger") }
            )
        }
    }

    test("Should generate QC plots (MDS, violin, PCA) from DESeq2 data and return PDF plots") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = DESEQ2_DE.out.unfiltered_log2counts
                input[3] = DESEQ2_DE.out.filtered_log2counts
                input[4] = DESEQ2_DE.out.normalized_log2counts
                input[5] = DESEQ2_DE.out.vst_object
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.qc_plots.get(0) ==~ ".*/qc_plots" },
                { assert snapshot(process.out.versions).match("versions_qcplots_deseq2") }
            )
        }
    }

    test("Should stub generate QC plots (MDS, violin, PCA) from edgeR data and return mocked PDF plots") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = EDGER_VOOM.out.voom_transformed
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = EDGER_VOOM.out.unfiltered_log2cpm
                input[3] = EDGER_VOOM.out.filtered_log2cpm
                input[4] = EDGER_VOOM.out.normalized_log2cpm
                input[5] = []
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("Should stub generate QC plots (MDS, violin, PCA) from DESeq2 data and return mocked PDF plots") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = DESEQ2_DE.out.unfiltered_log2counts
                input[3] = DESEQ2_DE.out.filtered_log2counts
                input[4] = DESEQ2_DE.out.normalized_log2counts
                input[5] = DESEQ2_DE.out.vst_object
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
