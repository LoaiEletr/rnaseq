nextflow_process {
    name "Test Process QC_VISUALIZATION"
    script "../main.nf"
    process "QC_VISUALIZATION"

    tag "modules"
    tag "modules_local"
    tag "qc_visualization"

    setup {
        run("EDGER_VOOM") {
            script "modules/local/edger_voom/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                """
            }
        }

        run("DESEQ2_DE") {
            script "modules/local/deseq2_de/main.nf"
            process {
                """
                input[0] = file(params.pipelines_testdata_base_path + 'count_matrices/tximport/leishmaniasis_raw_counts.rds', checkIfExists: true)
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = 0.05
                input[3] = 1
                input[4] = 100
                """
            }
        }
    }

    test("leishmaniasis - voom_transformed - samplesheet - unfiltered_log2cpm - filtered_log2cpm - normalized_log2cpm | edgeR") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = EDGER_VOOM.out.voom_transformed
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = EDGER_VOOM.out.unfiltered_log2cpm
                input[3] = EDGER_VOOM.out.filtered_log2cpm
                input[4] = EDGER_VOOM.out.normalized_log2cpm
                input[5] = []
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.qc_plots.get(0) ==~ ".*/qc_plots" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["qc_plots"])).match() }
            )
        }
    }

    test("leishmaniasis - samplesheet - unfiltered_log2cpm - filtered_log2cpm - normalized_log2cpm | DESeq2") {
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = DESEQ2_DE.out.unfiltered_log2counts
                input[3] = DESEQ2_DE.out.filtered_log2counts
                input[4] = DESEQ2_DE.out.normalized_log2counts
                input[5] = DESEQ2_DE.out.vst_object
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert process.out.qc_plots.get(0) ==~ ".*/qc_plots" },
                { assert snapshot(sanitizeOutput(process.out, unstableKeys:["qc_plots"])).match() }
            )
        }
    }

    test("leishmaniasis - voom_transformed - samplesheet - unfiltered_log2cpm - filtered_log2cpm - normalized_log2cpm - stub | edgeR") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = EDGER_VOOM.out.voom_transformed
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = EDGER_VOOM.out.unfiltered_log2cpm
                input[3] = EDGER_VOOM.out.filtered_log2cpm
                input[4] = EDGER_VOOM.out.normalized_log2cpm
                input[5] = []
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }

    test("leishmaniasis - samplesheet - unfiltered_log2cpm - filtered_log2cpm - normalized_log2cpm - stub | DESeq2") {
        options "-stub"
        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = []
                input[1] = file(params.pipelines_testdata_base_path + 'samplesheets/samplesheet_leishmaniasis.csv', checkIfExists: true)
                input[2] = DESEQ2_DE.out.unfiltered_log2counts
                input[3] = DESEQ2_DE.out.filtered_log2counts
                input[4] = DESEQ2_DE.out.normalized_log2counts
                input[5] = DESEQ2_DE.out.vst_object
                """
            }
        }
        then {
            assertAll(
                { assert process.success },
                { assert snapshot(process.out).match() }
            )
        }
    }
}
