/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        enabled: false
    ]

    //
    // PREPARE_GENOME
    //
    withName: 'PREPARE_GENOME:UNTAR_HISAT2_INDEX|PREPARE_GENOME:HISAT2_BUILD' {
        publishDir = [
            path: { params.save_reference ? "${params.outdir}/reference/hisat2" : params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename != 'versions.yml' && params.save_reference) ? filename : null }
        ]
    }

    withName: 'PREPARE_GENOME:UNTAR_SORTMERNA_INDEX|PREPARE_GENOME:SORTMERNA_INDEX' {
        publishDir = [
            path: { params.save_reference ? "${params.outdir}/reference/sortmerna" : params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename != 'versions.yml' && params.save_reference) ? filename : null }
        ]
    }

    withName: 'PREPARE_GENOME:UNTAR_BBSPLIT_INDEX|PREPARE_GENOME:BBSPLIT_INDEX' {
        publishDir = [
            path: { params.save_reference ? "${params.outdir}/reference/bbsplit" : params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename != 'versions.yml' && params.save_reference) ? filename : null }
        ]
    }

    withName: 'PREPARE_GENOME:UNTAR_SALMON_INDEX|PREPARE_GENOME:SALMON_INDEX' {
        publishDir = [
            path: { params.save_reference ? "${params.outdir}/reference/salmon" : params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename != 'versions.yml' && params.save_reference) ? filename : null }
        ]
    }

    withName: 'PREPARE_GENOME:GUNZIP_KALLISTO_INDEX|PREPARE_GENOME:KALLISTO_INDEX' {
        publishDir = [
            path: { params.save_reference ? "${params.outdir}/reference/kallisto" : params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename != 'versions.yml' && params.save_reference) ? filename : null }
        ]
    }

    withName : 'PREPARE_GENOME:GATK4_BEDTOINTERVALLIST' {
        ext.args    =  '--DROP_MISSING_CONTIGS TRUE'
    }

    withName : 'PREPARE_GENOME:GATK4_INTERVALLISTTOOLS'{
        ext.args    = { [
            '--SUBDIVISION_MODE BALANCING_WITHOUT_INTERVAL_SUBDIVISION_WITH_OVERFLOW',
            '--UNIQUE true',
            '--SORT true',
            params.gatk_interval_scatter_count ? "--SCATTER_COUNT ${params.gatk_interval_scatter_count}" : ''
        ].join(' ').trim() }
    }

    withName: 'PREPARE_GENOME:GUNZIP_GENOME|PREPARE_GENOME:GUNZIP_GTF|PREPARE_GENOME:GUNZIP_GFF|PREPARE_GENOME:GUNZIP_BED|PREPARE_GENOME:GXF2BED|PREPARE_GENOME:HISAT2_EXTRACTSPLICESITES|PREPARE_GENOME:HISAT2_EXTRACTEXONS|PREPARE_GENOME:DEXSEQ_PREPAREANNOTATION|PREPARE_GENOME:GUNZIP_FAI|PREPARE_GENOME:GUNZIP_DICT|PREPARE_GENOME:GUNZIP_INTERVALLIST|PREPARE_GENOME:SAMTOOLS_FAIDX|PREPARE_GENOME:GATK4_CREATESEQUENCEDICTIONARY|PREPARE_GENOME:GATK4_BEDTOINTERVALLIST|PREPARE_GENOME:GATK4_INTERVALLISTTOOLS' {
        publishDir = [
            path: { params.save_reference ? "${params.outdir}/reference/genome" : params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename != 'versions.yml' && params.save_reference) ? filename : null }
        ]
    }

    withName: 'PREPARE_GENOME:TABIX_TABIX_KNOWNSITES|PREPARE_GENOME:TABIX_TABIX_DBSNP' {
        publishDir = [
            path: { params.save_reference ? "${params.outdir}/reference/variation" : params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename != 'versions.yml' && params.save_reference) ? filename : null }
        ]
    }

    withName: 'PREPARE_GENOME:UNTAR_SNPEFF_DB|PREPARE_GENOME:SNPEFF_DOWNLOAD' {
        publishDir = [
            path: { params.save_reference ? "${params.outdir}/reference/snpeff" : params.outdir },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename != 'versions.yml' && params.save_reference) ? filename : null }
        ]
    }

    //
    // HISAT2_ALIGN
    //
    withName: '.*:HISAT2_ALIGN' {
        publishDir = [
            path: { "${params.outdir}/alignment/hisat2/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{bam,summary}",
        ]
    }

    //
    // FASTQ_FASTQC_EXTRACT_CUTADAPT_BBSPLIT_SORTMERNA
    //
    withName: '.*:FASTQ_FASTQC_EXTRACT_CUTADAPT_BBSPLIT_SORTMERNA:FASTQC_RAW' {
        ext.prefix = {"${meta.id}_raw"}
        publishDir = [
            path: { "${params.outdir}/quality_control/fastqc/raw/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{html,zip}',
            enabled: !params.skip_fastqc
        ]
    }
    withName: '.*:FASTQ_FASTQC_EXTRACT_CUTADAPT_BBSPLIT_SORTMERNA:FASTQC_TRIM' {
        ext.prefix = {"${meta.id}_trimmed"}
        publishDir = [
            path: { "${params.outdir}/quality_control/fastqc/trim/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{html,zip}',
            enabled: !params.skip_fastqc
        ]
    }
    withName: '.*:FASTQ_FASTQC_EXTRACT_CUTADAPT_BBSPLIT_SORTMERNA:UMITOOLS_EXTRACT' {
        ext.args = { [
            params.umi_extract_method ? "--extract-method=${params.umi_extract_method}" : '',
            params.umi_separator ? "--umi-separator=${params.umi_separator}" : '',
            params.umitools_bc_pattern ? "--bc-pattern ${params.umitools_bc_pattern}" :
                (params.lib_kit == "quantseq" ? "--bc-pattern '^(?P<umi_1>.{6})(?P<discard_1>.{4}).*'" :
                params.lib_kit == "corall"   ? "--bc-pattern '^(?P<umi_1>.{12}).*'" :
                params.lib_kit == "takara"   ? "--bc-pattern '^(?P<umi_1>.{8})(?P<discard_1>.{6}).*'" : ''),
            params.umitools_bc_pattern2 ? "--bc-pattern ${params.umitools_bc_pattern2}" : ''
        ].join(' ').trim() }
        publishDir = [
            path: { "${params.outdir}/preprocessing/umitools/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{fastq.gz,log}',
            enabled: params.with_umi
        ]
    }
    withName: '.*:FASTQ_FASTQC_EXTRACT_CUTADAPT_BBSPLIT_SORTMERNA:CUTADAPT' {
        ext.args    = { [
            meta.sequencer in ["NovaSeq","NextSeq"] ? "--nextseq-trim=20 -m 50" : "--max-n 0 -m 36",
            "-q 20,20"
        ].join(' ').trim() }
        publishDir = [
            path: { "${params.outdir}/preprocessing/trimmed/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*.{fastq.gz,json}',
            enabled: !params.skip_trimming
        ]
    }
    withName: '.*:FASTQ_FASTQC_EXTRACT_CUTADAPT_BBSPLIT_SORTMERNA:BBMAP_BBSPLIT' {
        ext.args    = [
            'maxindel=1000000',
            'minhits=1',
            'minratio=0.5'
        ].join(' ').trim()
        publishDir = [
            path: { "${params.outdir}/preprocessing/bbsplit/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*{primary*.fastq.gz,stats.txt}',
            enabled: !params.skip_bbsplit
        ]
    }
    withName: '.*:FASTQ_FASTQC_EXTRACT_CUTADAPT_BBSPLIT_SORTMERNA:SORTMERNA' {
        publishDir = [
            path: { "${params.outdir}/preprocessing/sortmerna/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: '*{non_rRNA*.fq.gz,.log}',
            enabled: !params.skip_sortmerna
        ]
    }

    //
    // FASTQ_SAMPLE_SEQKIT_SALMON
    //
    withName : '.*:FASTQ_SAMPLE_SEQKIT_SALMON:SEQKIT_SAMPLE' {
        ext.prefix = {"${meta.id}.subsample"}
        publishDir = [ enabled: false ]
    }
    withName : '.*:FASTQ_SAMPLE_SEQKIT_SALMON:SALMON_QUANT' {
        ext.args = "--skipQuant"
        ext.prefix = {"${meta.id}_subsamples"}
        publishDir = [ enabled: false ]
    }

    //
    // FASTQ_QUANT_PSEUDOALIGNMENT
    //
    withName: '.*:FASTQ_QUANT_PSEUDOALIGNMENT:KALLISTO_QUANT' {
        ext.args    = { params.bootstrap_count ? "-b ${params.bootstrap_count}" : '' }
        publishDir = [
            path: { "${params.outdir}/quantification/kallisto" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: '.*:FASTQ_QUANT_PSEUDOALIGNMENT:SALMON_QUANT' {
        publishDir = [
            path: { "${params.outdir}/quantification/salmon" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // BAM_SORT_INDEX_DEDUP_SAMTOOLS_UMITOOLS_FEATURECOUNTS
    //
    withName: '.*:BAM_SORT_INDEX_DEDUP_SAMTOOLS_UMITOOLS_FEATURECOUNTS:SAMTOOLS_SORT|.*:BAM_SORT_INDEX_DEDUP_SAMTOOLS_UMITOOLS_FEATURECOUNTS:SAMTOOLS_INDEX' {
        publishDir = [
            path: { "${params.outdir}/alignment/native/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{bam,bai}"
        ]
    }
    withName: '.*:BAM_SORT_INDEX_DEDUP_SAMTOOLS_UMITOOLS_FEATURECOUNTS:UMITOOLS_DEDUP' {
        ext.args = { [
            params.umi_post_extract_method ? "--extract-umi-method=${params.umi_post_extract_method}" : '',
            params.umi_separator ? "--umi-separator=${params.umi_separator}" : ''
        ].join(' ').trim() }
    }
    withName: '.*:BAM_SORT_INDEX_DEDUP_SAMTOOLS_UMITOOLS_FEATURECOUNTS:SAMTOOLS_SORT_DEDUP|.*:BAM_SORT_INDEX_DEDUP_SAMTOOLS_UMITOOLS_FEATURECOUNTS:SAMTOOLS_INDEX_DEDUP|.*:BAM_SORT_INDEX_DEDUP_SAMTOOLS_UMITOOLS_FEATURECOUNTS:UMITOOLS_DEDUP' {
        publishDir = [
            path: { "${params.outdir}/alignment/deduplicated/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*{.bam,.bai,.log,edit_distance.tsv,per_umi.tsv,per_position.tsv}",
            enabled: params.with_umi
        ]
    }
    withName: '.*:BAM_SORT_INDEX_DEDUP_SAMTOOLS_UMITOOLS_FEATURECOUNTS:SUBREAD_FEATURECOUNTS' {
        publishDir = [
            path: { "${params.outdir}/quantification/featurecounts/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.{counts.txt,summary}"
        ]
    }

    //
    // BAM_RSEQC
    //
    withName: '.*:BAM_RSEQC:RSEQC_.*' {
        publishDir = [
            path: { "${params.outdir}/quality_control/rseqc/${task.process.tokenize(':')[-1].toLowerCase().replace('rseqc_', '')}/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // COUNTS_MATRIXGENERATION
    //
    withName: '.*:COUNTS_MATRIXGENERATION:TX2GENE|.*:COUNTS_MATRIXGENERATION:TXIMPORT|.*:COUNTS_MATRIXGENERATION:MERGE_COUNTS' {
        publishDir = [
            path: { "${params.outdir}/quantification/merged_matrices" },
            mode: params.publish_dir_mode,
            pattern: "*.{tsv,rds}"
        ]
    }

    //
    // BAM_BAMLIST_AVGLEN_RMATS
    //
    withName: '.*:BAM_BAMLIST_AVGLEN_RMATS:RMATS_POST|.*:BAM_BAMLIST_AVGLEN_RMATS:RMATS_PREP' {
        ext.args = { [
            params.statoff ? '--statoff' : '',
            params.novelss ? '--novelSS' : '',
            params.allowclipping ? '--allow-clipping' : '',
            params.individualcounts ? '--individual-counts' : ''
        ].join(' ').trim() }
    }
    withName: '.*:BAM_BAMLIST_AVGLEN_RMATS:RMATS_POST|.*:BAM_BAMLIST_AVGLEN_RMATS:FILTER_SIGEVENTS|.*:BAM_BAMLIST_AVGLEN_RMATS:RMATS2SASHIMIPLOT' {
        publishDir = [
            path: { "${params.outdir}/differential_analysis/rmats" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // BAM_DEXSEQ_DEU_ENRICHMENT
    //
    withName: '.*:BAM_DEXSEQ_DEU_ENRICHMENT:DEXSEQ_COUNT' {
        publishDir = [
            path: { "${params.outdir}/differential_analysis/dexseq/counts/${meta.id}" },
            mode: params.publish_dir_mode,
            pattern: "*.counts.txt"
        ]
    }
    withName: '.*:BAM_DEXSEQ_DEU_ENRICHMENT:DEXSEQ_DEU|.*:BAM_DEXSEQ_DEU_ENRICHMENT:GO_ENRICHMENT|.*:BAM_DEXSEQ_DEU_ENRICHMENT:KEGG_ENRICHMENT' {
        publishDir = [
            path: { "${params.outdir}/differential_analysis/dexseq/results" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // COUNTS_ISOFORM_SWITCH_ENRICHMENT
    //
    withName: '.*:COUNTS_ISOFORM_SWITCH_ENRICHMENT:.*' {
        publishDir = [
            path: { "${params.outdir}/differential_analysis/isoform_switch" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION
    //
    withName: '.*:COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION:EDGER_VOOM|.*:COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION:LIMMA_DE|.*:COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION:DESEQ2_DE' {
        publishDir = [
            path: { "${params.outdir}/differential_analysis/gene_expression/stats" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: '.*:COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION:QC_VISUALIZATION|.*:COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION:DE_VISUALIZATION|.*:COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION:GO_ENRICHMENT|.*:COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION:KEGG_ENRICHMENT|.*:COUNTS_DIFFEXPR_QC_ENRICHMENT_VISUALIZATION:MSIGDB_GSEA' {
        publishDir = [
            path: { "${params.outdir}/differential_analysis/gene_expression/plots_and_enrichment" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // BAM_DEDUP_RECALIBRATE_PICARD_GATK
    //
    withName: '.*:BAM_DEDUP_RECALIBRATE_PICARD_GATK:PICARD_MARKDUPLICATES' {
        ext.args    = { [
            '--ASSUME_SORTED true',
            '--VALIDATION_STRINGENCY LENIENT',
            params.remove_duplicates ? '--REMOVE_DUPLICATES true' : ''
        ].join(' ').trim() }
        publishDir = [
            path: { "${params.outdir}/preprocessing/picard_metrics" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.metrics.txt') ? filename : null }
        ]
    }
    withName: '.*:BAM_DEDUP_RECALIBRATE_PICARD_GATK:GATK4_SPLITNCIGARREADS' {
        ext.args   = '--create-output-bam-index false'
        ext.prefix = { "${meta.id}.splitncigarreads" }
    }
    withName: '.*:BAM_DEDUP_RECALIBRATE_PICARD_GATK:GATK4_BASERECALIBRATOR' {
        ext.args   = '--use-original-qualities'
        ext.prefix = { "${meta.id}.baserecalibrator" }
        publishDir = [
            path: { "${params.outdir}/preprocessing/recalibration_tables" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }
    withName: '.*:BAM_DEDUP_RECALIBRATE_PICARD_GATK:GATK4_APPLYBQSR' {
        ext.args   = [
            '--use-original-qualities',
            '--add-output-sam-program-record'
        ].join(' ').trim()
        ext.prefix = { "${meta.id}.recal" }
    }
    withName: '.*:BAM_DEDUP_RECALIBRATE_PICARD_GATK:SAMTOOLS_MERGE_SPLIT|.*:BAM_DEDUP_RECALIBRATE_PICARD_GATK:SAMTOOLS_INDEX_MERGED' {
        publishDir = [
            path: { "${params.outdir}/preprocessing/split_ncigar_bam" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.skip_baserecalibration
        ]
    }
    withName: '.*:BAM_DEDUP_RECALIBRATE_PICARD_GATK:SAMTOOLS_MERGE_BQSR|.*:BAM_DEDUP_RECALIBRATE_PICARD_GATK:SAMTOOLS_INDEX_BQSR' {
        publishDir = [
            path: { "${params.outdir}/preprocessing/recalibrated_bam" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: !params.skip_baserecalibration
        ]
    }

    //
    // VCF_CALL_FILTER_GATK
    //
    withName: '.*:VCF_CALL_FILTER_GATK:GATK4_HAPLOTYPECALLER' {
        ext.prefix = { "${meta.id}.haplotypecaller" }
        ext.args   = [
            '--dont-use-soft-clipped-bases',
            '--create-output-variant-index true',
            params.gatk_hc_call_conf ? "--standard-min-confidence-threshold-for-calling ${params.gatk_hc_call_conf}" : ''
        ].join(' ').trim()
    }
    withName: '.*:VCF_CALL_FILTER_GATK:BCFTOOLS_MERGE|.*:VCF_CALL_FILTER_GATK:TABIX_TABIX_RAW' {
        publishDir = [
            path: { "${params.outdir}/variant_calling/raw_vcf" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: params.skip_variantfiltration
        ]
    }
    withName: '.*:VCF_CALL_FILTER_GATK:GATK4_VARIANTFILTRATION' {
        ext.prefix = { "${meta.id}.haplotypecaller.filtered" }
        ext.args   = [
            params.gatk_vf_window_size ? "--cluster-window-size ${params.gatk_vf_window_size}" : '',
            params.gatk_vf_cluster_size ? "--cluster-size ${params.gatk_vf_cluster_size}" : '',
            params.gatk_vf_fs_filter ? "--filter-name \"FS\" --filter-expression \"FS > ${params.gatk_vf_fs_filter}\" " : '',
            params.gatk_vf_qd_filter ? "--filter-name \"QD\" --filter-expression \"QD < ${params.gatk_vf_qd_filter}\" " : '',
        ].join(' ').trim()
        publishDir = [
            path: { "${params.outdir}/variant_calling/filtered_vcf" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: !params.skip_variantfiltration
        ]
    }
    withName: '.*:VCF_CALL_FILTER_GATK:TABIX_TABIX_FILTERED' {
        publishDir = [
            path: { "${params.outdir}/variant_calling/filtered_vcf" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
            enabled: !params.skip_variantfiltration
        ]
    }

    //
    // BCFTOOLS_ISEC
    //
    withName: '.*:BCFTOOLS_ISEC' {
        ext.args   = '-Oz'
        publishDir = [
            path: { "${params.outdir}/variant_calling/intersection" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    //
    // SNPEFF_SNPEFF
    //
    withName: '.*:SNPEFF_SNPEFF' {
        ext.prefix = { "${meta.id}.snpeff" }
        ext.args   = { '-nodownload -canon -v' }
        publishDir = [
            [
                path: { "${params.outdir}/variant_calling/annotated_vcf" },
                mode: params.publish_dir_mode,
                pattern: "*.ann.vcf"
            ],
            [
                path: { "${params.outdir}/variant_calling/reports/snpeff/${meta.id}" },
                mode: params.publish_dir_mode,
                pattern: "*.{csv,html,txt}"
            ]
        ]
    }

    //
    // MULTIQC
    //
    withName: '.*:MULTIQC' {
        publishDir = [
            path: { "${params.outdir}/quality_control/multiqc" },
            mode: params.publish_dir_mode,
            pattern: '*{.html,_data,_plots}',
            enabled: !params.skip_multiqc
        ]
    }
}
